---
source: tests/golden_python.rs
expression: contents
---
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "out"
version = "0.1.0"
description = "Multi Scheme API MCP server, generated by mcpify."
requires-python = ">=3.11"
dependencies = [
  "mcp>=1.0",
  "aiosqlite>=0.20",
  "sqlite-vec>=0.1",
  "httpx>=0.27",
  "fastapi>=0.115",
  "uvicorn[standard]>=0.30",
  "jsonschema>=4.23",
  "structlog>=24.4",
  "opentelemetry-sdk>=1.27",
  "opentelemetry-exporter-otlp>=1.27",
  "opentelemetry-exporter-prometheus>=0.48b0",
  "sentence-transformers>=3.1",
  "authlib>=1.3",
  "pydantic-settings>=2.5",
  "typer>=0.12",
  "questionary>=2.0",
  "keyring>=25.4",
  "pyyaml>=6.0",
  "cryptography>=43",
]

[project.scripts]
out = "out.cli:main"

[tool.hatch.build.targets.wheel]
packages = ["src/out"]

[dependency-groups]
dev = [
  "pytest>=8.3",
  "pytest-asyncio>=0.24",
  "ruff>=0.7",
  "black>=24.10",
]

[tool.black]
line-length = 100
target-version = ["py311"]

[tool.ruff]
line-length = 100
target-version = "py311"

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
