"""{{ display_name }} MCP server — generated by mcpify. Do not hand-edit.

`jsonschema`-based input/output validation. Schemas themselves are NOT
embedded in this file — they're loaded from the co-located
`generated_schemas.json` asset (written directly by the Rust generator,
not templated, keeping this file's size independent of how many
operations the source spec declares).
"""

from __future__ import annotations

import json
from functools import lru_cache
from pathlib import Path
from typing import Any

import jsonschema

from ..core.errors import ValidationError

_SCHEMAS_PATH = Path(__file__).parent / "generated_schemas.json"


@lru_cache(maxsize=1)
def _schemas_by_operation() -> dict[str, dict[str, Any]]:
    try:
        return json.loads(_SCHEMAS_PATH.read_text())
    except (OSError, json.JSONDecodeError):
        return {}


@lru_cache(maxsize=None)
def _validator_for(operation_id: str, schema_key: str) -> jsonschema.protocols.Validator:
    schema = _schemas_by_operation().get(operation_id, {}).get(schema_key, {})
    validator_cls = jsonschema.validators.validator_for(schema)
    return validator_cls(schema)


def _validate_against(operation_id: str, schema_key: str, data: Any) -> list[str]:
    validator = _validator_for(operation_id, schema_key)
    return [error.message for error in validator.iter_errors(data)]


def validate_input(operation_id: str, data: Any) -> None:
    """Raises `ValidationError` if `data` doesn't satisfy `operation_id`'s
    input schema.
    """
    errors = _validate_against(operation_id, "inputSchema", data)
    if errors:
        raise ValidationError(f"invalid input for '{operation_id}'", details=errors)


def validate_output(operation_id: str, data: Any) -> None:
    """Raises `ValidationError` if `data` doesn't satisfy `operation_id`'s
    output schema — surfaces upstream API drift as a structured error
    rather than silently returning a mismatched response (architecture.md's
    `call` pipeline).
    """
    errors = _validate_against(operation_id, "outputSchema", data)
    if errors:
        raise ValidationError(f"unexpected response shape for '{operation_id}'", details=errors)
