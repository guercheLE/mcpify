"""{{ display_name }} MCP server — generated by mcpify. Do not hand-edit.

Regression test for Fix 8b (embedding population completeness): asserts
that every version's `semantic_endpoints` row count EQUALS its
`endpoints` row count — not just "greater than zero". A store can end up
with `endpoints` rows but only some (or none) of the matching
`semantic_endpoints` rows if `services/populate_embeddings.py` was
interrupted mid-run, run against a stale checkout, or (before Fix 8a)
defaulted to only the default version's store. The `search` tool
silently returns incomplete/empty results for an under-populated version
with no error ever surfaced, so this must be caught here rather than
discovered live.

Unlike `tests/unit` and `tests/integration` (self-contained, seeded via
`conftest.py`'s `seeded_db_path`) and `tests/e2e` (builds its own
temporary db with the real embedding model), this test reads the actual
on-disk `mcp_store*.db` files at the project root — the bytes that would
ship in a package/container image. Right after `mcpify
generate`/`add-version`, before anyone has run
`python -m {{ module_name }}.services.populate_embeddings --all`, every
`semantic_endpoints` table is legitimately still empty, and this
project's CI workflow (`.github/workflows/ci.yml`) never runs that
populate step before `uv run pytest` — so this test is skipped unless
explicitly opted into via the `RUN_PACKAGING_TESTS` environment variable.
Run it as a packaging/release smoke test, after populating:

    uv run python -m {{ module_name }}.services.populate_embeddings --all
    RUN_PACKAGING_TESTS=true uv run pytest tests/packaging/test_embeddings_populated.py
"""

from __future__ import annotations

import os
import sqlite3
from pathlib import Path

import pytest
import sqlite_vec

from {{ module_name }}.data.store import VERSION_STORE_FILES

pytestmark = pytest.mark.skipif(
    os.environ.get("RUN_PACKAGING_TESTS") != "true",
    reason="requires 'populate_embeddings --all' to have been run first against the real "
    "on-disk store files; opt in with RUN_PACKAGING_TESTS=true",
)

_PROJECT_ROOT = Path(__file__).resolve().parents[2]


def _open_readonly(db_path: Path) -> sqlite3.Connection:
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    conn.enable_load_extension(True)
    sqlite_vec.load(conn)
    conn.enable_load_extension(False)
    return conn


def test_semantic_endpoints_row_count_matches_endpoints_row_count_for_every_version() -> None:
    mismatches: list[str] = []

    for label, file_name in VERSION_STORE_FILES.items():
        db_path = _PROJECT_ROOT / file_name
        assert db_path.exists(), (
            f"'{label}': store file '{db_path}' does not exist — run 'mcpify generate'/"
            "'mcpify add-version' before this packaging test"
        )

        conn = _open_readonly(db_path)
        try:
            (endpoints_count,) = conn.execute("SELECT count(*) FROM endpoints").fetchone()
            (semantic_count,) = conn.execute("SELECT count(*) FROM semantic_endpoints").fetchone()
        finally:
            conn.close()

        if endpoints_count != semantic_count:
            mismatches.append(f"'{label}': endpoints={endpoints_count} semantic_endpoints={semantic_count}")

    assert not mismatches, (
        "embedding population incomplete — semantic_endpoints row count must equal endpoints "
        "row count for every version, but found mismatch(es): " + "; ".join(mismatches)
    )
