from __future__ import annotations

import aiosqlite
import pytest

from {{ module_name }}.core.errors import NotFoundError
from {{ module_name }}.tools.get_tool import get_operation


async def test_returns_a_seeded_endpoint(store_conn: aiosqlite.Connection) -> None:
    result = await get_operation(store_conn, "listWidgets")
    assert result["path"] == "/widgets"
    assert result["method"] == "GET"
    assert result["summary"] == "List widgets"


async def test_raises_not_found_for_an_unknown_operation(store_conn: aiosqlite.Connection) -> None:
    with pytest.raises(NotFoundError):
        await get_operation(store_conn, "unknownOp")
