"""{{ display_name }} MCP server — generated by mcpify. Do not hand-edit.

Interactive setup wizard (REQ-1.6): collects the API URL and the
credentials the discovered auth scheme(s) need, then persists them per
the operator's choice: a .env file, a global/local YAML config file (the
same tiers and format `core.config.load_config` actually reads back — see
`_prompt_persistence`), or a ready-to-run CLI invocation printed to stdout
(nothing written to disk). `questionary` prompts are `asyncio`-native
(`.ask_async()`), unlike v2's `inquire`, which needs `spawn_blocking`.
"""

from __future__ import annotations

{%- if "oauth2" in auth_method_keys %}
import asyncio
{%- endif %}
import json
{%- if "oauth2" in auth_method_keys %}
import os
{%- endif %}
from pathlib import Path
from typing import Any
{%- if "oauth2" in auth_method_keys %}
from urllib.parse import parse_qs, urlencode, urlsplit
{%- endif %}

import httpx
import questionary
import yaml

from ..auth.auth_manager import header_location_for
{%- if "oauth2" in auth_method_keys %}
from ..auth.strategies.oauth2 import create_pkce_pair
{%- endif %}
from ..core.config import CONFIG_DIR_NAME, LOCAL_CONFIG_FILE, AuthMethod, Transport
from ..core.config import _home_dir as _config_home_dir
from ..core.credential_storage import save_credential


def _to_env_key(key: str) -> str:
    return key.upper()


async def _prompt_base_url() -> str:
    url = await questionary.text("{{ display_name }} base URL:").ask_async()

    try:
        async with httpx.AsyncClient(timeout=5) as client:
            await client.head(url)
        print("reachable")
    except httpx.HTTPError:
        print(
            "could not reach that URL yet — continuing anyway "
            "(fix it later with `test-connection`)"
        )

    return url


async def _prompt_auth_method() -> AuthMethod:
{%- if auth_methods | length == 1 %}
    # Exactly one scheme was discovered — nothing to choose between.
    return AuthMethod.{{ auth_methods.0.class_name | upper }}
{%- else %}
    choices = [{% for method in auth_methods %}"{{ method.key }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    selection = await questionary.select("Authentication method:", choices).ask_async()
    return AuthMethod(selection)
{%- endif %}


async def _prompt_transport() -> Transport:
    choices = [
        "stdio (spawned as a subprocess by the MCP client)",
        "http (a standalone server the MCP client connects to over the network)",
    ]
    selection = await questionary.select("Which transport will this deployment use?", choices).ask_async()
    return Transport.STDIO if selection.startswith("stdio") else Transport.HTTP


# mcpify:versions:begin
async def _prompt_api_version() -> str:
{%- if version_entries | length == 1 %}
    # Only one version is available — nothing to choose between.
    return "{{ version_entries.0.label }}"
{%- else %}
    choices = [
    {%- for v in version_entries %}
        "{{ v.label }}{% if v.label == default_version_label %} (default/latest){% endif %}",
    {%- endfor %}
    ]
    selection = await questionary.select("API version to use:", choices).ask_async()
    return selection.split(" ")[0]
{%- endif %}
# mcpify:versions:end


{%- if "oauth2" in auth_method_keys %}
{%- for method in auth_methods %}
{%- if method.key == "oauth2" %}
async def _build_oauth2_setup() -> tuple[dict[str, str], str, bool, int]:
    """Collects client ID/secret, scopes, generates PKCE, and builds the
    authorization URL — everything the browser step needs, before this
    wizard starts (or skips) the local callback server. Returns
    ``(credentials, auth_url, use_callback, callback_port)``.
    """
    print(
        "\n"
        "══════════════════════════════════════════════════════════════════════\n"
        "{{ display_name }} OAuth2 Setup\n"
        "You need an OAuth2 app registered with this API provider.\n"
        "══════════════════════════════════════════════════════════════════════"
    )

    credentials: dict[str, str] = {}

    # Client ID and secret aren't per-user secrets — RFC 8252 classifies
    # CLI/native apps as OAuth "public clients": client_id is a bare
    # identifier, and even a client_secret (when one exists — PKCE is the
    # actual protection for this class of client) "should not be treated
    # as confidential". So, unlike the actual tokens this wizard goes on
    # to collect, it's fine to default these from env vars — the same
    # convenience pattern gcloud/aws-style CLIs use for app-level config,
    # letting an operator re-run setup without retyping their app's
    # identity every time.
    env_client_id = os.environ.get("{{ tool_prefix_env }}_CLIENT_ID")
    env_client_secret = os.environ.get("{{ tool_prefix_env }}_CLIENT_SECRET")

    client_id = await questionary.text("OAuth2 client ID:", default=env_client_id or "").ask_async()
    credentials["client_id"] = client_id

    if env_client_secret:
        print("Client Secret: using {{ tool_prefix_env }}_CLIENT_SECRET from the environment.")
        client_secret = env_client_secret
    else:
        client_secret = await questionary.password(
            "OAuth2 client secret (leave blank to use PKCE-only — recommended, no secret required):"
        ).ask_async()
    use_pkce = not client_secret
    if not use_pkce:
        credentials["client_secret"] = client_secret

    token_url = await questionary.text(
        "OAuth2 token URL:"{% if method.token_url %}, default="{{ method.token_url }}"{% endif %}
    ).ask_async()
    credentials["token_url"] = token_url

    auth_base = await questionary.text(
        "OAuth2 authorization URL (where the browser goes to authorize):"{% if method.authorization_url %}, default="{{ method.authorization_url }}"{% endif %}
    ).ask_async()

    scope = await questionary.text(
        "OAuth2 scopes (space-separated — accept the default for full access):"{% if method.scopes %}, default="{{ method.scopes }}"{% endif %}
    ).ask_async()

    # Redirect URI — MUST be registered with the OAuth2 app.
    callback_port = 8888
    redirect_uri = f"http://127.0.0.1:{callback_port}/callback"
    credentials["redirect_uri"] = redirect_uri

    # PKCE: generate code_verifier/code_challenge when not using a secret.
    code_challenge: str | None = None
    if use_pkce:
        verifier, code_challenge = create_pkce_pair()
        credentials["code_verifier"] = verifier

    # Build the authorization URL. The user opens this in their browser to
    # grant permission; the provider then redirects to
    # redirect_uri?code=<authorization_code>.
    params = {
        "response_type": "code",
        "client_id": client_id,
        "redirect_uri": redirect_uri,
        "scope": scope,
    }
    if code_challenge:
        params["code_challenge_method"] = "S256"
        params["code_challenge"] = code_challenge
    auth_url = f"{auth_base}?{urlencode(params)}"

    use_callback = await questionary.confirm(
        f"Start a local callback server on {redirect_uri} to capture the\n"
        "authorization code automatically after you authorize in the browser?",
        default=True,
    ).ask_async()

    return credentials, auth_url, use_callback, callback_port


async def _wait_for_oauth_callback(port: int) -> str:
    """Temporary local HTTP server that receives the OAuth2 redirect and
    extracts the `?code=` query parameter, then shuts itself down. A
    hand-rolled `asyncio.start_server` rather than the FastAPI/uvicorn
    stack the `http` transport uses — that stack owns the process's
    signal handling, which doesn't compose well with a server meant to
    live for one request in the middle of an interactive wizard.
    """
    code_future: asyncio.Future[str] = asyncio.get_event_loop().create_future()

    async def handle(reader: asyncio.StreamReader, writer: asyncio.StreamWriter) -> None:
        request_line = await reader.readline()
        while True:
            line = await reader.readline()
            if not line or line in (b"\r\n", b"\n"):
                break
        try:
            _, path, _ = request_line.decode("latin-1").split(" ", 2)
        except ValueError:
            path = "/"
        query = parse_qs(urlsplit(path).query)
        code = query.get("code", [""])[0]
        body = (
            b"<!DOCTYPE html><html><body><h1>&#10003; Authorized!</h1>"
            b"<p>Return to your terminal &mdash; setup continues automatically.</p>"
            b"</body></html>"
        )
        writer.write(
            b"HTTP/1.1 200 OK\r\n"
            b"Content-Type: text/html\r\n"
            b"Content-Length: " + str(len(body)).encode() + b"\r\n"
            b"Connection: close\r\n\r\n" + body
        )
        await writer.drain()
        writer.close()
        await writer.wait_closed()
        if not code_future.done():
            code_future.set_result(code)

    server = await asyncio.start_server(handle, "127.0.0.1", port)
    async with server:
        try:
            return await asyncio.wait_for(code_future, timeout=300)
        except TimeoutError as err:
            raise RuntimeError("timed out waiting for the OAuth2 callback (5 minutes)") from err
{%- endif %}
{%- endfor %}
{%- endif %}


async def _prompt_credentials(auth_method: AuthMethod) -> dict[str, str]:
    credentials: dict[str, str] = {}
{%- if "basic" in auth_method_keys %}
    if auth_method is AuthMethod.BASIC:
        credentials["username"] = await questionary.text("Username:").ask_async()
        credentials["password"] = await questionary.password("Password:").ask_async()
{%- endif %}
{%- if "pat" in auth_method_keys %}
    if auth_method is AuthMethod.PAT:
        credentials["token"] = await questionary.password("Personal access token:").ask_async()
{%- endif %}
{%- if "apiKey" in auth_method_keys %}
    if auth_method is AuthMethod.APIKEY:
        credentials["api_key"] = await questionary.password("API key:").ask_async()
{%- endif %}
{%- if "oauth2" in auth_method_keys %}
    if auth_method is AuthMethod.OAUTH2:
        oauth2_credentials, auth_url, use_callback, callback_port = await _build_oauth2_setup()

        bar = "═" * 72
        print(f"\n{bar}")
        print("Open this URL in your browser to authorize:")
        print(auth_url)
        print(bar)
        print(
            "\nIMPORTANT: Before opening the URL, register this Redirect URI with your "
            f"OAuth2 app:\n  http://127.0.0.1:{callback_port}/callback\n"
        )

        if use_callback:
            print(f"Waiting for callback on http://127.0.0.1:{callback_port}/callback …")
            authorization_code = await _wait_for_oauth_callback(callback_port)
        else:
            authorization_code = await questionary.text(
                "Paste the authorization code from the redirect URL (?code=...):"
            ).ask_async()

        credentials.update(oauth2_credentials)
        credentials["authorization_code"] = authorization_code
{%- endif %}
{%- if "oauth1" in auth_method_keys %}
    if auth_method is AuthMethod.OAUTH1:
        credentials["consumer_key"] = await questionary.text("OAuth1 consumer key:").ask_async()
        private_key_path = await questionary.text("Path to RSA private key file:").ask_async()
        credentials["private_key"] = Path(private_key_path).read_text()
{%- endif %}
    return credentials


async def _prompt_persistence(config_values: dict[str, Any], env: dict[str, str]) -> None:
    """Persists settings per the operator's choice. The two YAML options
    write to exactly the paths/format `core.config.load_config`'s cascade
    reads back (local cwd file before the global home-dir file — see that
    module's docstring), so the wizard's output is never silently ignored
    on the next run. `config_values` deliberately excludes credentials:
    those already went through `save_credential`'s OS-keychain/encrypted-
    file path in `run_setup_wizard`, and must never be duplicated into a
    plaintext config file.
    """
    choices = [
        "Write a .env file",
        f"Write a local config file (./{LOCAL_CONFIG_FILE})",
        f"Write a global config file (~/{CONFIG_DIR_NAME}/config.yml)",
        "Print a ready-to-run CLI invocation (nothing written to disk)",
    ]
    selection = await questionary.select("How should these settings be saved?", choices).ask_async()

    if selection == "Write a .env file":
        contents = "\n".join(f"{key}={value}" for key, value in env.items())
        Path(".env").write_text(f"{contents}\n")
        print("Wrote .env")
    elif selection.startswith("Write a local config file"):
        config_path = Path(LOCAL_CONFIG_FILE)
        config_path.write_text(yaml.safe_dump(config_values, sort_keys=False))
        print(f"Wrote {config_path}")
    elif selection.startswith("Write a global config file"):
        config_dir = _config_home_dir() / CONFIG_DIR_NAME
        config_dir.mkdir(parents=True, exist_ok=True)
        config_path = config_dir / "config.yml"
        config_path.write_text(yaml.safe_dump(config_values, sort_keys=False))
        print(f"Wrote {config_path}")
    else:
        flags = " ".join(
            f"--{key.lower().replace('_', '-')} {value!r}" for key, value in env.items()
        )
        print(f"{{ project_name }} start {flags}")


def _print_mcp_client_config(transport: Transport, auth_method: AuthMethod, env: dict[str, str]) -> None:
    """Prints a ready-to-use MCP client config (the `mcpServers` block a
    host like Claude Code/Desktop expects) for whichever transport was
    selected — the stdio and http shapes are mutually exclusive, never
    both, since they're two different ways of running this same server
    and a client only ever picks one. HTTP transport shows credentials as
    headers only (never env/CLI args, matching
    `AuthManager.apply_auth_headers`'s HTTP-only-uses-per-request-
    credentials behavior); stdio shows both the `env` block and the
    equivalent all-CLI-args invocation, since the config cascade accepts
    either for a spawned subprocess.
    """
    if transport is Transport.STDIO:
        config = {
            "mcpServers": {
                "{{ project_name }}": {
                    "command": "{{ project_name }}",
                    "args": ["start"],
                    "env": env,
                }
            }
        }
        print("\nMCP client config (stdio):")
        print(json.dumps(config, indent=2))
        cli_args = " ".join(
            f"--{key.lower().replace('_', '-')} {value!r}" for key, value in env.items()
        )
        print(f"(equivalently: `{{ project_name }} start {cli_args}`)")
        return

    {%- if "oauth1" in auth_method_keys %}
    if auth_method is AuthMethod.OAUTH1:
        print(
            "\nOAuth1 is not supported over HTTP transport: its signature must be "
            "recomputed per request against the destination URL using the server's "
            "consumer key/secret, which a simple incoming-header relay cannot "
            "provide. Use stdio transport for this API instead."
        )
        return
    {%- endif %}
    _, header_name = header_location_for(auth_method)
    config = {
        "mcpServers": {
            "{{ project_name }}": {
                "url": "http://127.0.0.1:3000/mcp",
                "headers": {header_name: "<credential value here>"},
            }
        }
    }
    print("\nMCP client config (http) — adjust the host/port to match how you run `{{ project_name }} http`:")
    print(json.dumps(config, indent=2))
    print(
        f'Credentials are never read from local config/env over HTTP transport — '
        f'every request must carry its own "{header_name}" header.'
    )


async def run_setup_wizard() -> None:
    url = await _prompt_base_url()
    auth_method = await _prompt_auth_method()
    credentials = await _prompt_credentials(auth_method)
    api_version = await _prompt_api_version()
    transport = await _prompt_transport()

    save_credential("active-credentials", json.dumps(credentials))

    env: dict[str, str] = {
        "{{ tool_prefix_env }}_URL": url,
        "{{ tool_prefix_env }}_AUTH_METHOD": auth_method.value,
        "{{ tool_prefix_env }}_API_VERSION": api_version,
        "{{ tool_prefix_env }}_TRANSPORT": transport.value,
    }
    for key, value in credentials.items():
        {%- if "oauth2" in auth_method_keys %}
        if auth_method is AuthMethod.OAUTH2 and key in (
            "authorization_code",
            "code_verifier",
            "redirect_uri",
            "token_url",
        ):
            # Single-use (authorization_code, code_verifier — an
            # authorization code is spent in minutes and a PKCE verifier
            # is useless without it) or provider-fixed (redirect_uri,
            # token_url — already baked into the keychain blob
            # save_credential wrote above) fields. Persisting these to
            # .env/config.yml/CLI args would either leak a spent code or
            # go stale the moment the provider rotates an endpoint.
            continue
        {%- endif %}
        env[f"{{ tool_prefix_env }}_{_to_env_key(key)}"] = value

    # Non-secret settings only, keyed by the `Config` model's own field
    # names (what `load_config`'s YAML layers merge into `Config(**merged)`)
    # — credentials are deliberately excluded; they already went through
    # `save_credential` above.
    config_values: dict[str, Any] = {
        "url": url,
        "auth_method": auth_method.value,
        "api_version": api_version,
        "transport": transport.value,
    }

    await _prompt_persistence(config_values, env)
    _print_mcp_client_config(transport, auth_method, env)

    run_command = "start" if transport is Transport.STDIO else "http"
    print(f"Setup complete! Run: {{ project_name }} {run_command}")
