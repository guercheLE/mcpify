// asset (written directly by the Rust generator, not templated) at
// runtime, keeping this file's size independent of how many operations the
// source spec declares.

import { readFileSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';

// Named import, not default: ajv ships no `exports` map (legacy CJS-only
// package), which makes default-import interop unreliable under
// "moduleResolution": "NodeNext" — the named `Ajv` class export sidesteps
// that ambiguity entirely.
import { Ajv, type ValidateFunction } from 'ajv';

import { ValidationError } from '../core/errors.js';

interface OperationSchemas {
  inputSchema: unknown;
  outputSchema: unknown;
}

const SCHEMAS_PATH = join(dirname(fileURLToPath(import.meta.url)), 'generated-schemas.json');
const schemasByOperation = JSON.parse(readFileSync(SCHEMAS_PATH, 'utf8')) as Record<string, OperationSchemas>;

const ajv = new Ajv({ allErrors: true, strict: false });
const compiledInput = new Map<string, ValidateFunction>();
const compiledOutput = new Map<string, ValidateFunction>();

function inputValidator(operationId: string): ValidateFunction {
  let validate = compiledInput.get(operationId);
  if (!validate) {
    validate = ajv.compile(schemasByOperation[operationId]?.inputSchema ?? {});
    compiledInput.set(operationId, validate);
  }
  return validate;
}

function outputValidator(operationId: string): ValidateFunction {
  let validate = compiledOutput.get(operationId);
  if (!validate) {
    validate = ajv.compile(schemasByOperation[operationId]?.outputSchema ?? {});
    compiledOutput.set(operationId, validate);
  }
  return validate;
}

/** Throws `ValidationError` if `data` doesn't satisfy `operationId`'s input schema. */
export function validateInput(operationId: string, data: unknown): void {
  const validate = inputValidator(operationId);
  if (!validate(data)) {
    throw new ValidationError(`invalid input for '${operationId}'`, validate.errors);
  }
}

/**
 * Throws `ValidationError` if `data` doesn't satisfy `operationId`'s output
 * schema — surfaces upstream API drift as a structured error rather than
 * silently returning a mismatched response (architecture.md's `call`
 * pipeline).
 */
export function validateOutput(operationId: string, data: unknown): void {
  const validate = outputValidator(operationId);
  if (!validate(data)) {
    throw new ValidationError(`unexpected response shape for '${operationId}'`, validate.errors);
  }
}
