#!/usr/bin/env node
// {{ display_name }} MCP server — generated by mcpify. Do not hand-edit.
//
// Harness Server entry point: boots the persistent MCP server loop for
// consumption by an agent harness (Claude Desktop, Cursor, custom
// orchestrators). Run directly (`node dist/index.js`) or via
// `{{ project_name }} start` / `{{ project_name }} http` (see cli.ts).

import { AuthManager } from './auth/auth-manager.js';
import { loadConfig } from './core/config-manager.js';
import { ComponentRegistry } from './core/component-registry.js';
import { HealthCheckManager } from './core/health-check-manager.js';
import { logger } from './core/logger.js';
import { connectStdio, createMcpServer } from './core/mcp-server.js';
import { installShutdownHandlers, onShutdown } from './core/shutdown-handler.js';
import { initTracing, shutdownTracing } from './core/tracing.js';
import { getCachedStore } from './data/store-repository.js';
import { startHttpServer } from './http/http-server.js';
import { registerTools } from './tools/register-tools.js';

/**
 * Bootstrap order (architecture.md's Runtime Target Architecture): config ->
 * logger -> registry -> shutdown-handler -> db -> auth -> services -> McpServer
 * -> register tools -> pick transport -> health checks.
 */
export async function main(): Promise<void> {
  const config = loadConfig();
  initTracing();
  installShutdownHandlers();
  onShutdown(shutdownTracing);

  const registry = new ComponentRegistry();
  const healthChecks = new HealthCheckManager(registry);

  const store = getCachedStore(config.api_version);
  healthChecks.register('store', async () => {
    await store.healthCheck();
  });

  const authManager = new AuthManager(config.auth_method);

  const server = createMcpServer();
  registerTools(server, { store, config, authManager });

  healthChecks.start();
  onShutdown(() => healthChecks.stop());

  if (config.transport === 'http') {
    await startHttpServer(server, config, registry);
    logger.info({ host: config.host, port: config.port }, 'MCP server listening over HTTP');
  } else {
    await connectStdio(server);
  }
}

if (import.meta.url === `file://${process.argv[1]}`) {
  main().catch((error: unknown) => {
    logger.error({ err: error }, 'fatal error during startup');
    process.exit(1);
  });
}
