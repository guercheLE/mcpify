import { afterAll, describe, expect, it } from 'vitest';

import { closeStore, openStore } from '../../../src/data/store-repository.js';
import { searchOperations } from '../../../src/tools/search-tool.js';

const store = openStore();
afterAll(() => closeStore(store));

describe('searchOperations', () => {
  it('returns an array of results without throwing', async () => {
    const results = await searchOperations(store, 'find an operation', 5);
    expect(Array.isArray(results)).toBe(true);
  });

  it('respects the limit parameter', async () => {
    const results = await searchOperations(store, 'find an operation', 1);
    expect(results.length).toBeLessThanOrEqual(1);
  });
});
