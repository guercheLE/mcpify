import { describe, expect, it } from 'vitest';

import { PatAuthStrategy } from '../../../src/auth/strategies/pat.js';

describe('PatAuthStrategy', () => {
  it('builds a Bearer Authorization header from the token', async () => {
    const strategy = new PatAuthStrategy();
    const credentials = await strategy.authenticate({ token: 'abc123' });
    expect(credentials.authorizationHeader).toBe('Bearer abc123');
  });

  it('throws when the token is missing', async () => {
    const strategy = new PatAuthStrategy();
    await expect(strategy.authenticate({})).rejects.toThrow();
  });
});
