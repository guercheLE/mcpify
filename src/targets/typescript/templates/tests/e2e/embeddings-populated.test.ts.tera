// {{ display_name }} MCP server — generated by mcpify. Do not hand-edit.
//
// Only runs when RUN_E2E_TESTS=true (see vitest.config.ts) — right after
// `mcpify generate`/`add-version`, before anyone has run
// `npm run populate-embeddings -- --all`, every `semantic_endpoints`
// table is legitimately still empty, and this project's CI workflow
// (`.github/workflows/ci.yml`) never runs that populate step before
// `npm test`.
//
// Regression test for Fix 8b (embedding population completeness):
// asserts that every version's `semantic_endpoints` row count EQUALS its
// `endpoints` row count — not just "greater than zero". A store can end
// up with `endpoints` rows but only some (or none) of the matching
// `semantic_endpoints` rows if `scripts/populate-embeddings.ts` was
// interrupted mid-run, run against a stale checkout, or (before Fix 8a)
// defaulted to only the default version's store. The `search` tool
// silently returns incomplete/empty results for an under-populated
// version with no error ever surfaced, so this must be caught here
// rather than discovered live. Reads the real on-disk `mcp_store*.db`
// files (via `openStore`), unlike `tests/unit`/`tests/integration`,
// which seed their own temporary db.

import { afterEach, describe, expect, it } from 'vitest';

import { closeStore, openStore, VERSION_STORE_FILES, type Store } from '../../src/data/store-repository.js';

let openStores: Store[] = [];

afterEach(() => {
  for (const store of openStores) {
    closeStore(store);
  }
  openStores = [];
});

describe('embeddings population', () => {
  it('has a matching semantic_endpoints row count for every version\'s endpoints row count', () => {
    const mismatches: string[] = [];

    for (const label of Object.keys(VERSION_STORE_FILES)) {
      const store = openStore(label);
      openStores.push(store);

      const { count: endpointsCount } = store.db
        .prepare('SELECT count(*) AS count FROM endpoints')
        .get() as { count: number };
      const { count: semanticCount } = store.db
        .prepare('SELECT count(*) AS count FROM semantic_endpoints')
        .get() as { count: number };

      if (endpointsCount !== semanticCount) {
        mismatches.push(`'${label}': endpoints=${endpointsCount} semantic_endpoints=${semanticCount}`);
      }
    }

    expect(
      mismatches,
      `embedding population incomplete — semantic_endpoints row count must equal endpoints row ` +
        `count for every version, but found mismatch(es): ${mismatches.join('; ')}`,
    ).toEqual([]);
  });
});
