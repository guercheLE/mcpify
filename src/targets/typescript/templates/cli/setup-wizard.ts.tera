// {{ display_name }} MCP server — generated by mcpify. Do not hand-edit.
//
// Interactive setup wizard (REQ-1.6): collects the API URL and the
// credentials the discovered auth scheme(s) need, then persists them per
// the operator's choice: a .env file, a config.yml file (global or local —
// whichever the config loader's cascade in core/config-manager.ts actually
// reads), or a ready-to-run CLI invocation printed to stdout (nothing
// written to disk).

import { mkdirSync, writeFileSync } from 'node:fs';
{%- if "oauth2" in auth_method_keys %}
import { createServer } from 'node:http';
{%- endif %}
import { homedir } from 'node:os';
import { join } from 'node:path';

import axios from 'axios';
import inquirer from 'inquirer';
import yaml from 'js-yaml';

import { headerLocationFor } from '../auth/auth-manager.js';
{%- if "oauth2" in auth_method_keys %}
import { createPkcePair } from '../auth/strategies/oauth2.js';
{%- endif %}
import type { ApiVersion, AuthMethod, Config } from '../core/config-schema.js';
import { saveCredential } from '../core/credential-storage.js';

function toEnvKey(key: string): string {
  return key.replace(/([a-z0-9])([A-Z])/g, '$1_$2').toUpperCase();
}

async function promptBaseUrl(): Promise<string> {
  const { url } = await inquirer.prompt<{ url: string }>([
    { type: 'input', name: 'url', message: '{{ display_name }} base URL:' },
  ]);
  try {
    await axios.head(url, { timeout: 5000 });
    console.log('reachable');
  } catch {
    console.warn('could not reach that URL yet — continuing anyway (fix it later with `test-connection`)');
  }
  return url;
}

async function promptAuthMethod(): Promise<AuthMethod> {
{%- if auth_method_keys | length == 1 %}
  return '{{ auth_method_keys.0 }}';
{%- else %}
  const { authMethod } = await inquirer.prompt<{ authMethod: AuthMethod }>([
    {
      type: 'list',
      name: 'authMethod',
      message: 'Authentication method:',
      choices: [
  {%- for key in auth_method_keys %}
        '{{ key }}',
  {%- endfor %}
      ],
    },
  ]);
  return authMethod;
{%- endif %}
}

async function promptTransport(): Promise<Config['transport']> {
  const { transport } = await inquirer.prompt<{ transport: Config['transport'] }>([
    {
      type: 'list',
      name: 'transport',
      message: 'Which transport will this deployment use?',
      choices: [
        { name: 'stdio (spawned as a subprocess by the MCP client)', value: 'stdio' },
        { name: 'http (a standalone server the MCP client connects to over the network)', value: 'http' },
      ],
    },
  ]);
  return transport;
}

// mcpify:versions:begin
async function promptApiVersion(): Promise<ApiVersion> {
{%- if version_entries | length == 1 %}
  return '{{ version_entries.0.label }}';
{%- else %}
  const { apiVersion } = await inquirer.prompt<{ apiVersion: ApiVersion }>([
    {
      type: 'list',
      name: 'apiVersion',
      message: 'API version to use:',
      default: '{{ default_version_label }}',
      choices: [
  {%- for v in version_entries %}
        { name: '{{ v.label }}{% if v.label == default_version_label %} (default/latest){% endif %}', value: '{{ v.label }}' },
  {%- endfor %}
      ],
    },
  ]);
  return apiVersion;
{%- endif %}
}
// mcpify:versions:end

{%- if "oauth2" in auth_method_keys %}
{%- for method in auth_method_locations %}
{%- if method.key == "oauth2" %}

interface OAuth2Setup {
  credentials: Record<string, string>;
  authUrl: string;
  useCallback: boolean;
  callbackPort: number;
}

/** Collects client ID/secret, scopes, generates PKCE, and builds the
 * authorization URL — everything the browser step needs, before this
 * wizard starts (or skips) the local callback server. */
async function buildOAuth2Setup(): Promise<OAuth2Setup> {
  console.log(
    '\n' +
      '══════════════════════════════════════════════════════════════════════\n' +
      '{{ display_name }} OAuth2 Setup\n' +
      'You need an OAuth2 app registered with this API provider.\n' +
      '══════════════════════════════════════════════════════════════════════',
  );

  const credentials: Record<string, string> = {};

  // Client ID and secret aren't per-user secrets — RFC 8252 classifies
  // CLI/native apps as OAuth "public clients": client_id is a bare
  // identifier, and even a client_secret (when one exists — PKCE is the
  // actual protection for this class of client) "should not be treated
  // as confidential". So, unlike the actual tokens this wizard goes on
  // to collect, it's fine to default these from env vars — the same
  // convenience pattern gcloud/aws-style CLIs use for app-level config,
  // letting an operator re-run setup without retyping their app's
  // identity every time.
  const envClientId = process.env['{{ tool_prefix_env }}_CLIENT_ID'];
  const envClientSecret = process.env['{{ tool_prefix_env }}_CLIENT_SECRET'];

  const { clientId } = await inquirer.prompt<{ clientId: string }>([
    { type: 'input', name: 'clientId', message: 'OAuth2 client ID:', default: envClientId },
  ]);
  credentials.clientId = clientId;

  let clientSecret: string;
  if (envClientSecret) {
    console.log('Client Secret: using {{ tool_prefix_env }}_CLIENT_SECRET from the environment.');
    clientSecret = envClientSecret;
  } else {
    ({ clientSecret } = await inquirer.prompt<{ clientSecret: string }>([
      {
        type: 'password',
        name: 'clientSecret',
        message: 'OAuth2 client secret (leave blank to use PKCE-only — recommended, no secret required):',
      },
    ]));
  }
  const usePkce = clientSecret.length === 0;
  if (!usePkce) {
    credentials.clientSecret = clientSecret;
  }

  const { tokenUrl } = await inquirer.prompt<{ tokenUrl: string }>([
    {
      type: 'input',
      name: 'tokenUrl',
      message: 'OAuth2 token URL:',
      {%- if method.token_url %}
      default: '{{ method.token_url }}',
      {%- endif %}
    },
  ]);
  credentials.tokenUrl = tokenUrl;

  const { authBase } = await inquirer.prompt<{ authBase: string }>([
    {
      type: 'input',
      name: 'authBase',
      message: 'OAuth2 authorization URL (where the browser goes to authorize):',
      {%- if method.authorization_url %}
      default: '{{ method.authorization_url }}',
      {%- endif %}
    },
  ]);

  const { scope } = await inquirer.prompt<{ scope: string }>([
    {
      type: 'input',
      name: 'scope',
      message: 'OAuth2 scopes (space-separated — accept the default for full access):',
      {%- if method.scopes %}
      default: '{{ method.scopes }}',
      {%- endif %}
    },
  ]);

  // Redirect URI — MUST be registered with the OAuth2 app.
  const callbackPort = 8888;
  const redirectUri = `http://127.0.0.1:${callbackPort}/callback`;
  credentials.redirectUri = redirectUri;

  // PKCE: generate codeVerifier/codeChallenge when not using a secret.
  let codeChallenge: string | undefined;
  if (usePkce) {
    const { verifier, challenge } = createPkcePair();
    credentials.codeVerifier = verifier;
    codeChallenge = challenge;
  }

  // Build the authorization URL. The user opens this in their browser to
  // grant permission; the provider then redirects to
  // redirectUri?code=<authorizationCode>.
  const params = new URLSearchParams({
    response_type: 'code',
    client_id: clientId,
    redirect_uri: redirectUri,
    scope,
  });
  if (codeChallenge) {
    params.set('code_challenge_method', 'S256');
    params.set('code_challenge', codeChallenge);
  }
  const authUrl = `${authBase}?${params.toString()}`;

  const { useCallback } = await inquirer.prompt<{ useCallback: boolean }>([
    {
      type: 'confirm',
      name: 'useCallback',
      message: `Start a local callback server on ${redirectUri} to capture the\nauthorization code automatically after you authorize in the browser?`,
      default: true,
    },
  ]);

  return { credentials, authUrl, useCallback, callbackPort };
}

/** Temporary local HTTP server that receives the OAuth2 redirect and
 * extracts the `?code=` query parameter, then shuts itself down. */
async function waitForOAuthCallback(port: number): Promise<string> {
  return new Promise<string>((resolve, reject) => {
    const server = createServer((req, res) => {
      const url = new URL(req.url ?? '/', `http://127.0.0.1:${port}`);
      if (url.pathname !== '/callback') {
        res.writeHead(404).end();
        return;
      }
      const code = url.searchParams.get('code') ?? '';
      res.writeHead(200, { 'Content-Type': 'text/html' }).end(
        '<!DOCTYPE html><html><body><h1>&#10003; Authorized!</h1>' +
          '<p>Return to your terminal &mdash; setup continues automatically.</p></body></html>',
      );
      clearTimeout(timeout);
      server.close();
      resolve(code);
    });
    const timeout = setTimeout(() => {
      server.close();
      reject(new Error('timed out waiting for the OAuth2 callback (5 minutes)'));
    }, 300_000);
    server.listen(port, '127.0.0.1');
  });
}
{%- endif %}
{%- endfor %}
{%- endif %}

async function promptCredentials(authMethod: AuthMethod): Promise<Record<string, string>> {
  switch (authMethod) {
{%- if "basic" in auth_method_keys %}
    case 'basic':
      return inquirer.prompt([
        { type: 'input', name: 'username', message: 'Username:' },
        { type: 'password', name: 'password', message: 'Password:' },
      ]);
{%- endif %}
{%- if "pat" in auth_method_keys %}
    case 'pat':
      return inquirer.prompt([{ type: 'password', name: 'token', message: 'Personal access token:' }]);
{%- endif %}
{%- if "apiKey" in auth_method_keys %}
    case 'apiKey':
      return inquirer.prompt([{ type: 'password', name: 'apiKey', message: 'API key:' }]);
{%- endif %}
{%- if "oauth2" in auth_method_keys %}
    case 'oauth2': {
      const setup = await buildOAuth2Setup();

      const bar = '═'.repeat(72);
      console.log(`\n${bar}`);
      console.log('Open this URL in your browser to authorize:');
      console.log(setup.authUrl);
      console.log(bar);
      console.log(
        `\nIMPORTANT: Before opening the URL, register this Redirect URI with your OAuth2 app:\n  http://127.0.0.1:${setup.callbackPort}/callback\n`,
      );

      let authorizationCode: string;
      if (setup.useCallback) {
        console.log(`Waiting for callback on http://127.0.0.1:${setup.callbackPort}/callback …`);
        authorizationCode = await waitForOAuthCallback(setup.callbackPort);
      } else {
        ({ authorizationCode } = await inquirer.prompt<{ authorizationCode: string }>([
          {
            type: 'input',
            name: 'authorizationCode',
            message: 'Paste the authorization code from the redirect URL (?code=...):',
          },
        ]));
      }

      return { ...setup.credentials, authorizationCode };
    }
{%- endif %}
{%- if "oauth1" in auth_method_keys %}
    case 'oauth1':
      return inquirer.prompt([
        { type: 'input', name: 'consumerKey', message: 'OAuth1 consumer key:' },
        { type: 'input', name: 'privateKeyPath', message: 'Path to RSA private key file:' },
      ]);
{%- endif %}
    default:
      return {};
  }
}

async function promptConfigScope(): Promise<'global' | 'local'> {
  const { scope } = await inquirer.prompt<{ scope: 'global' | 'local' }>([
    {
      type: 'list',
      name: 'scope',
      message: 'Write the config file globally or locally?',
      choices: [
        {
          name: 'Globally (~/.{{ project_name }}/config.yml — applies on this machine regardless of cwd)',
          value: 'global',
        },
        {
          name: 'Locally (./{{ project_name }}.config.yml — applies only when run from this directory)',
          value: 'local',
        },
      ],
    },
  ]);
  return scope;
}

/**
 * `configFields` holds only the non-secret keys `core/config-manager.ts`'s
 * `envOverrides()`/cascade actually reads back (`url`, `auth_method`,
 * `api_version`, `transport`, ...) — credentials are deliberately excluded
 * here and persisted only through `saveCredential()` (OS keychain /
 * encrypted file), never written to a plaintext config file.
 */
async function promptPersistence(
  env: Record<string, string>,
  configFields: Record<string, string>,
): Promise<void> {
  const { method } = await inquirer.prompt<{ method: 'env' | 'yaml' | 'print' }>([
    {
      type: 'list',
      name: 'method',
      message: 'How should these settings be saved?',
      choices: [
        { name: 'Write a .env file', value: 'env' },
        { name: 'Write a config.yml file (read by the config loader)', value: 'yaml' },
        { name: 'Print a ready-to-run CLI invocation (nothing written to disk)', value: 'print' },
      ],
    },
  ]);

  if (method === 'env') {
    const contents = Object.entries(env)
      .map(([key, value]) => `${key}=${value}`)
      .join('\n');
    writeFileSync(join(process.cwd(), '.env'), `${contents}\n`);
    console.log('Wrote .env');
  } else if (method === 'yaml') {
    const scope = await promptConfigScope();
    const configDir = join(homedir(), '.{{ project_name }}');
    const configPath =
      scope === 'global' ? join(configDir, 'config.yml') : join(process.cwd(), '{{ project_name }}.config.yml');
    if (scope === 'global') {
      mkdirSync(configDir, { recursive: true, mode: 0o700 });
    }
    writeFileSync(configPath, yaml.dump(configFields));
    console.log(`Wrote ${configPath}`);
  } else {
    const flags = Object.entries(env)
      .map(([key, value]) => `--${key.toLowerCase().replace(/_/g, '-')} ${JSON.stringify(value)}`)
      .join(' ');
    console.log(`{{ project_name }} start ${flags}`);
  }
}

/**
 * Prints a ready-to-use MCP client config (the `mcpServers` block a host
 * like Claude Code/Desktop expects) for whichever transport was selected
 * — the stdio and http shapes are mutually exclusive, never both, since
 * they're two different ways of running this same server and a client
 * only ever picks one. HTTP transport shows credentials as headers only
 * (never env/CLI args, matching `AuthManager.applyAuthHeaders`'s
 * HTTP-only-uses-per-request-credentials behavior); stdio shows both the
 * `env` block and the equivalent all-CLI-args invocation, since the
 * config cascade accepts either for a spawned subprocess.
 */
function printMcpClientConfig(transport: Config['transport'], authMethod: AuthMethod, env: Record<string, string>): void {
  if (transport === 'stdio') {
    const config = {
      mcpServers: {
        ['{{ project_name }}']: {
          command: '{{ project_name }}',
          args: ['start'],
          env,
        },
      },
    };
    console.log('\nMCP client config (stdio):');
    console.log(JSON.stringify(config, null, 2));
    const cliArgs = Object.entries(env)
      .map(([key, value]) => `--${key.toLowerCase().replace(/_/g, '-')} ${JSON.stringify(value)}`)
      .join(' ');
    console.log(`(equivalently: \`{{ project_name }} start ${cliArgs}\`)`);
    return;
  }

{%- if "oauth1" in auth_method_keys %}
  if (authMethod === 'oauth1') {
    console.log(
      "\nOAuth1 is not supported over HTTP transport: its signature must be recomputed per " +
        "request against the destination URL using the server's consumer key/secret, which a " +
        'simple incoming-header relay cannot provide. Use stdio transport for this API instead.',
    );
    return;
  }
{%- endif %}
  const [, headerName] = headerLocationFor(authMethod);
  const config = {
    mcpServers: {
      ['{{ project_name }}']: {
        url: 'http://127.0.0.1:3000/mcp',
        headers: { [headerName]: '<credential value here>' },
      },
    },
  };
  console.log('\nMCP client config (http) — adjust the host/port to match how you run `{{ project_name }} http`:');
  console.log(JSON.stringify(config, null, 2));
  console.log(
    `Credentials are never read from local config/env over HTTP transport — every request must carry its own "${headerName}" header.`,
  );
}

export async function runSetupWizard(): Promise<void> {
  const url = await promptBaseUrl();
  const authMethod = await promptAuthMethod();
  const credentials = await promptCredentials(authMethod);
  const apiVersion = await promptApiVersion();
  const transport = await promptTransport();

  await saveCredential('active-credentials', JSON.stringify(credentials));

  const env: Record<string, string> = {
    ['{{ tool_prefix_env }}_URL']: url,
    ['{{ tool_prefix_env }}_AUTH_METHOD']: authMethod,
    ['{{ tool_prefix_env }}_API_VERSION']: apiVersion,
    ['{{ tool_prefix_env }}_TRANSPORT']: transport,
  };
  for (const [key, value] of Object.entries(credentials)) {
    {%- if "oauth2" in auth_method_keys %}
    if (
      authMethod === 'oauth2' &&
      ['authorizationCode', 'codeVerifier', 'redirectUri', 'tokenUrl'].includes(key)
    ) {
      // Single-use (authorizationCode, codeVerifier — an authorization
      // code is spent in minutes and a PKCE verifier is useless without
      // it) or provider-fixed (redirectUri, tokenUrl — already baked into
      // the keychain blob saveCredential wrote above) fields. Persisting
      // these to .env/config.yml/CLI args would either leak a spent code
      // or go stale the moment the provider rotates an endpoint.
      continue;
    }
    {%- endif %}
    env[`{{ tool_prefix_env }}_${toEnvKey(key)}`] = value;
  }

  const configFields: Record<string, string> = {
    url,
    auth_method: authMethod,
    api_version: apiVersion,
    transport,
  };

  await promptPersistence(env, configFields);
  printMcpClientConfig(transport, authMethod, env);

  const runCommand = transport === 'stdio' ? 'start' : 'http';
  console.log(`Setup complete! Run: {{ project_name }} ${runCommand}`);
}
