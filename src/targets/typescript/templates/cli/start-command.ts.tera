// {{ display_name }} MCP server — generated by mcpify. Do not hand-edit.

import type { Command } from 'commander';

import { main } from '../index.js';

export function registerStartCommand(program: Command): void {
  program
    .command('start')
    .description('Start the Harness Server over stdio (for agent hosts)')
    .action(async () => {
      process.env['{{ tool_prefix_env }}_TRANSPORT'] = 'stdio';
      await main();
    });
}
