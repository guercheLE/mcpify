// {{ display_name }} MCP server — generated by mcpify. Do not hand-edit.
//
// Interactive setup wizard (REQ-1.6): collects the API URL and the
// credentials the discovered auth scheme(s) need, then persists them per
// the operator's choice: a .env file, a local or global config.yml file,
// or a ready-to-run CLI invocation printed to stdout (nothing written to
// disk).
// `inquire`'s prompts are blocking — run through `spawn_blocking`, the
// same pattern mcpify's own `auth_profile::prompt` documents for calling
// it from an async runtime.

use std::collections::HashMap;
use std::time::Duration;

use {{ crate_name }}::core::config_schema::{AuthMethod, Transport};
use {{ crate_name }}::core::credential_storage::save_credential;
{%- if "oauth2" in auth_method_keys %}
use percent_encoding::{NON_ALPHANUMERIC, utf8_percent_encode};
{%- endif %}

fn to_env_key(key: &str) -> String {
    key.to_uppercase()
}

async fn prompt_base_url() -> anyhow::Result<String> {
    let url = tokio::task::spawn_blocking(|| inquire::Text::new("{{ display_name }} base URL:").prompt())
        .await??;

    let client = reqwest::Client::new();
    match client
        .head(&url)
        .timeout(Duration::from_secs(5))
        .send()
        .await
    {
        Ok(_) => println!("reachable"),
        Err(_) => println!(
            "could not reach that URL yet — continuing anyway (fix it later with `test-connection`)"
        ),
    }

    Ok(url)
}

async fn prompt_auth_method() -> anyhow::Result<AuthMethod> {
    {%- if auth_methods | length == 1 %}
    // Exactly one scheme was discovered — nothing to choose between.
    Ok(AuthMethod::{{ auth_methods.0.variant_name }})
    {%- else %}
    let choices = vec![{% for method in auth_methods %}"{{ method.key }}"{% if not loop.last %}, {% endif %}{% endfor %}];
    let selection = tokio::task::spawn_blocking(move || {
        inquire::Select::new("Authentication method:", choices).prompt()
    })
    .await??;

    Ok(match selection {
    {%- for method in auth_methods %}
        "{{ method.key }}" => AuthMethod::{{ method.variant_name }},
    {%- endfor %}
        other => anyhow::bail!("unexpected auth method selection '{other}'"),
    })
    {%- endif %}
}

// mcpify:versions:begin
async fn prompt_api_version() -> anyhow::Result<String> {
    {%- if version_entries | length == 1 %}
    Ok("{{ version_entries.0.label }}".to_string())
    {%- else %}
    let choices = vec![
    {%- for v in version_entries %}
        "{{ v.label }}{% if v.label == default_version_label %} (default/latest){% endif %}",
    {%- endfor %}
    ];
    let selection = tokio::task::spawn_blocking(move || {
        inquire::Select::new("API version to use:", choices).prompt()
    })
    .await??;

    Ok(match selection {
    {%- for v in version_entries %}
        "{{ v.label }}{% if v.label == default_version_label %} (default/latest){% endif %}" => "{{ v.label }}".to_string(),
    {%- endfor %}
        other => other.to_string(),
    })
    {%- endif %}
}
// mcpify:versions:end

async fn prompt_transport() -> anyhow::Result<Transport> {
    let choices = vec!["stdio (spawned as a subprocess by the MCP client)", "http (a standalone server the MCP client connects to over the network)"];
    let selection = tokio::task::spawn_blocking(move || {
        inquire::Select::new("Which transport will this deployment use?", choices).prompt()
    })
    .await??;

    Ok(if selection.starts_with("stdio") {
        Transport::Stdio
    } else {
        Transport::Http
    })
}

{%- if "oauth2" in auth_method_keys %}
{%- for method in auth_methods %}
{%- if method.key == "oauth2" %}

/// Returned from the blocking prompt phase so the async caller can start
/// the callback server only after all user prompts have finished.
struct OAuth2Setup {
    credentials: HashMap<String, String>,
    auth_url: String,
    use_callback: bool,
    callback_port: u16,
}

fn build_oauth_authorization(
    credentials: &mut HashMap<String, String>,
    scope: &str,
    callback_port: u16,
    use_pkce: bool,
) -> anyhow::Result<String> {
    let redirect_uri = format!("http://127.0.0.1:{callback_port}/callback");
    credentials.insert("redirect_uri".to_string(), redirect_uri.clone());

    let code_challenge = if use_pkce {
        let (verifier, challenge) =
            {{ crate_name }}::auth::strategies::oauth2::create_pkce_pair();
        credentials.insert("code_verifier".to_string(), verifier);
        Some(challenge)
    } else {
        None
    };

    let client_id = credentials
        .get("client_id")
        .ok_or_else(|| anyhow::anyhow!("OAuth2 setup requires client_id"))?;
    let auth_base = credentials
        .get("auth_url")
        .ok_or_else(|| anyhow::anyhow!("OAuth2 setup requires auth_url"))?;
    let mut auth_url = format!(
        "{}?response_type=code\
         &client_id={}\
         &redirect_uri={}\
         &scope={}",
        auth_base,
        utf8_percent_encode(client_id, NON_ALPHANUMERIC),
        utf8_percent_encode(&redirect_uri, NON_ALPHANUMERIC),
        utf8_percent_encode(scope, NON_ALPHANUMERIC),
    );
    if let Some(challenge) = code_challenge {
        auth_url.push_str(&format!(
            "&code_challenge_method=S256&code_challenge={}",
            utf8_percent_encode(&challenge, NON_ALPHANUMERIC),
        ));
    }
    Ok(auth_url)
}

/// Blocking phase: collects client_id/secret, scopes, generates PKCE,
/// builds the authorization URL, and asks whether to use the local
/// callback server or paste the code manually. Must be called via
/// `spawn_blocking` — drives blocking `inquire` prompts.
fn build_oauth2_setup_blocking() -> anyhow::Result<OAuth2Setup> {
    println!(
        "\n\
         ══════════════════════════════════════════════════════════════════════\n\
         {{ display_name }} OAuth2 Setup\n\
         You need an OAuth2 app registered with this API provider.\n\
         ══════════════════════════════════════════════════════════════════════"
    );

    let mut credentials = HashMap::new();

    // Client ID and secret aren't per-user secrets — RFC 8252 classifies
    // CLI/native apps as OAuth "public clients": client_id is a bare
    // identifier, and even a client_secret (when one exists — PKCE is the
    // actual protection for this class of client) "should not be treated
    // as confidential". So, unlike the actual tokens this wizard goes on
    // to collect, it's fine to default these from env vars — the same
    // convenience pattern `gcloud`/`aws`-style CLIs use for app-level
    // config, letting an operator re-run setup without retyping their
    // app's identity every time.
    let env_client_id = std::env::var("{{ tool_prefix_env }}_CLIENT_ID").ok();
    let env_client_secret = std::env::var("{{ tool_prefix_env }}_CLIENT_SECRET").ok();

    let mut client_id_prompt = inquire::Text::new("OAuth2 client ID:");
    if let Some(default_id) = &env_client_id {
        client_id_prompt = client_id_prompt.with_default(default_id);
    }
    credentials.insert("client_id".to_string(), client_id_prompt.prompt()?);

    // Client Secret — leave blank to use the PKCE-only flow (recommended).
    // `inquire::Password` has no `with_default` (sensibly — a visible
    // default would defeat the point of a masked prompt), so if
    // {{ tool_prefix_env }}_CLIENT_SECRET is already set, use it directly
    // and skip the prompt instead of faking a default.
    let client_secret = match &env_client_secret {
        Some(secret) => {
            println!(
                "Client Secret: using {{ tool_prefix_env }}_CLIENT_SECRET from the environment."
            );
            secret.clone()
        }
        None => inquire::Password::new(
            "OAuth2 client secret (leave blank to use PKCE-only — recommended, no secret required):",
        )
        .without_confirmation()
        .prompt()?,
    };
    let use_pkce = client_secret.is_empty();
    if !use_pkce {
        credentials.insert("client_secret".to_string(), client_secret);
    }

    let token_url = inquire::Text::new("OAuth2 token URL:")
        {%- if method.token_url %}
        .with_default("{{ method.token_url }}")
        {%- endif %}
        .prompt()?;
    credentials.insert("token_url".to_string(), token_url);

    let auth_base = inquire::Text::new("OAuth2 authorization URL (where the browser goes to authorize):")
        {%- if method.authorization_url %}
        .with_default("{{ method.authorization_url }}")
        {%- endif %}
        .prompt()?;
    credentials.insert("auth_url".to_string(), auth_base.clone());

    let scope = inquire::Text::new(
        "OAuth2 scopes (space-separated — accept the default for full access):",
    )
    {%- if method.scopes %}
    .with_default("{{ method.scopes }}")
    {%- endif %}
    .prompt()?;

    let callback_port: u16 = 8888;
    let auth_url = build_oauth_authorization(&mut credentials, &scope, callback_port, use_pkce)?;
    let redirect_uri = credentials["redirect_uri"].clone();

    let use_callback = inquire::Confirm::new(&format!(
        "Start a local callback server on {redirect_uri} to capture the\n\
         authorization code automatically after you authorize in the browser?",
    ))
    .with_default(true)
    .prompt()?;

    Ok(OAuth2Setup {
        credentials,
        auth_url,
        use_callback,
        callback_port,
    })
}

/// Temporary local HTTP server that receives the OAuth2 redirect and
/// extracts the `?code=` query parameter, then shuts itself down.
async fn wait_for_oauth_callback(port: u16) -> anyhow::Result<String> {
    let addr: std::net::SocketAddr = format!("127.0.0.1:{port}").parse()?;
    let listener = tokio::net::TcpListener::bind(addr).await?;
    receive_oauth_callback(listener).await
}

async fn receive_oauth_callback(listener: tokio::net::TcpListener) -> anyhow::Result<String> {
    use axum::{Router, extract::Query, routing::get};
    use std::sync::{Arc, Mutex};
    use tokio::sync::oneshot;

    let (tx, rx) = oneshot::channel::<String>();
    let tx = Arc::new(Mutex::new(Some(tx)));
    let tx_clone = tx.clone();

    let app = Router::new().route(
        "/callback",
        get(move |Query(params): Query<HashMap<String, String>>| {
            let tx = tx_clone.clone();
            async move {
                let code = params.get("code").cloned().unwrap_or_default();
                if let Ok(mut guard) = tx.lock()
                    && let Some(sender) = guard.take()
                {
                    let _ = sender.send(code);
                }
                axum::response::Html(
                    "<!DOCTYPE html><html><body>\
                     <h1>&#10003; Authorized!</h1>\
                     <p>Return to your terminal &mdash; setup continues automatically.</p>\
                     </body></html>",
                )
            }
        }),
    );

    let server = tokio::spawn(async move {
        let _ = axum::serve(listener, app).await;
    });

    let code = tokio::time::timeout(Duration::from_secs(300), rx)
        .await
        .map_err(|_| anyhow::anyhow!("timed out waiting for the OAuth2 callback (5 minutes)"))?
        .map_err(|_| anyhow::anyhow!("OAuth2 callback channel closed unexpectedly"))?;

    server.abort();
    Ok(code)
}
{%- endif %}
{%- endfor %}
{%- endif %}

async fn prompt_credentials(auth_method: AuthMethod) -> anyhow::Result<HashMap<String, String>> {
    match auth_method {
        {%- if "basic" in auth_method_keys %}
        AuthMethod::Basic => {
            tokio::task::spawn_blocking(move || -> anyhow::Result<HashMap<String, String>> {
                let mut credentials = HashMap::new();
                credentials.insert(
                    "username".to_string(),
                    inquire::Text::new("Username:").prompt()?,
                );
                credentials.insert(
                    "password".to_string(),
                    inquire::Password::new("Password:")
                        .without_confirmation()
                        .prompt()?,
                );
                Ok(credentials)
            })
            .await?
        }
        {%- endif %}
        {%- if "pat" in auth_method_keys %}
        AuthMethod::Pat => {
            tokio::task::spawn_blocking(move || -> anyhow::Result<HashMap<String, String>> {
                let mut credentials = HashMap::new();
                credentials.insert(
                    "token".to_string(),
                    inquire::Password::new("Personal access token:")
                        .without_confirmation()
                        .prompt()?,
                );
                Ok(credentials)
            })
            .await?
        }
        {%- endif %}
        {%- if "apiKey" in auth_method_keys %}
        AuthMethod::ApiKey => {
            tokio::task::spawn_blocking(move || -> anyhow::Result<HashMap<String, String>> {
                let mut credentials = HashMap::new();
                credentials.insert(
                    "api_key".to_string(),
                    inquire::Password::new("API key:")
                        .without_confirmation()
                        .prompt()?,
                );
                Ok(credentials)
            })
            .await?
        }
        {%- endif %}
        {%- if "oauth2" in auth_method_keys %}
        AuthMethod::OAuth2 => {
            let setup = tokio::task::spawn_blocking(build_oauth2_setup_blocking).await??;

            let bar = "═".repeat(72);
            println!("\n{bar}");
            println!("Open this URL in your browser to authorize:");
            println!("{}", setup.auth_url);
            println!("{bar}");
            println!(
                "\nIMPORTANT: Before opening the URL, register this Redirect URI with your \
                 OAuth2 app:\n  http://127.0.0.1:{}/callback\n",
                setup.callback_port
            );

            let authorization_code = if setup.use_callback {
                println!(
                    "Waiting for callback on http://127.0.0.1:{}/callback …",
                    setup.callback_port
                );
                wait_for_oauth_callback(setup.callback_port).await?
            } else {
                tokio::task::spawn_blocking(|| {
                    inquire::Text::new(
                        "Paste the authorization code from the redirect URL (?code=...):",
                    )
                    .prompt()
                })
                .await??
            };

            let mut credentials = setup.credentials;
            credentials.insert("authorization_code".to_string(), authorization_code);
            Ok(credentials)
        }
        {%- endif %}
        {%- if "oauth1" in auth_method_keys %}
        AuthMethod::OAuth1 => {
            tokio::task::spawn_blocking(move || -> anyhow::Result<HashMap<String, String>> {
                let mut credentials = HashMap::new();
                credentials.insert(
                    "consumer_key".to_string(),
                    inquire::Text::new("OAuth1 consumer key:").prompt()?,
                );
                let private_key_path =
                    inquire::Text::new("Path to RSA private key file:").prompt()?;
                let private_key = std::fs::read_to_string(&private_key_path)
                    .map_err(|err| anyhow::anyhow!("failed to read '{private_key_path}': {err}"))?;
                credentials.insert("private_key".to_string(), private_key);
                Ok(credentials)
            })
            .await?
        }
        {%- endif %}
    }
}

/// Persists the non-secret config fields (`url`/`auth_method`/`api_version`/
/// `transport`) as YAML matching exactly what `config_manager::load_config`
/// reads back — never the credential fields, which stay in the OS
/// keychain/encrypted-file fallback via `save_credential` (called by the
/// caller before this runs). Writing anywhere else (a stray `.env`-only
/// var name, `config.json`, etc.) would leave the persisted config silently
/// ignored on every subsequent run, since `load_config`'s cascade only ever
/// reads `./{{ project_name }}.config.yml` (local) or
/// `~/.{{ project_name }}/config.yml` (global).
async fn write_config_yaml(
    path: &std::path::Path,
    config_fields: &serde_json::Value,
) -> anyhow::Result<()> {
    let yaml = serde_yaml::to_string(config_fields)?;
    if let Some(parent) = path.parent()
        && !parent.as_os_str().is_empty()
    {
        std::fs::create_dir_all(parent)?;
    }
    std::fs::write(path, yaml)?;
    println!("Wrote {}", path.display());
    println!(
        "Credentials are never written to this file — they're stored via the OS \
         keychain/encrypted-file fallback from the credential prompt above."
    );
    Ok(())
}

async fn prompt_persistence(
    env: &HashMap<String, String>,
    config_fields: &serde_json::Value,
) -> anyhow::Result<()> {
    let choices = vec![
        "Write a .env file",
        "Write a config.yml file (global — ~/.{{ project_name }}/config.yml, read on every invocation on this machine)",
        "Write a config.yml file (local — ./{{ project_name }}.config.yml, read only from this directory)",
        "Print a ready-to-run CLI invocation (nothing written to disk)",
    ];
    let selection = tokio::task::spawn_blocking(move || {
        inquire::Select::new("How should these settings be saved?", choices).prompt()
    })
    .await??;

    persist_selection(selection, env, config_fields).await
}

async fn persist_selection(
    selection: &str,
    env: &HashMap<String, String>,
    config_fields: &serde_json::Value,
) -> anyhow::Result<()> {
    let local_dir = std::env::current_dir()?;
    let global_config = {{ crate_name }}::core::credential_storage::resolve_home_dir()
        .join(".{{ project_name }}/config.yml");
    persist_selection_at(selection, env, config_fields, &local_dir, &global_config).await
}

async fn persist_selection_at(
    selection: &str,
    env: &HashMap<String, String>,
    config_fields: &serde_json::Value,
    local_dir: &std::path::Path,
    global_config: &std::path::Path,
) -> anyhow::Result<()> {
    match selection {
        "Write a .env file" => {
            let contents = env
                .iter()
                .map(|(key, value)| format!("{key}={value}"))
                .collect::<Vec<_>>()
                .join("\n");
            std::fs::write(local_dir.join(".env"), format!("{contents}\n"))?;
            println!("Wrote .env");
        }
        s if s.starts_with("Write a config.yml file (global") => {
            write_config_yaml(global_config, config_fields).await?;
        }
        s if s.starts_with("Write a config.yml file (local") => {
            write_config_yaml(&local_dir.join("{{ project_name }}.config.yml"), config_fields)
                .await?;
        }
        _ => {
            let flags = env
                .iter()
                .map(|(key, value)| {
                    format!("--{} {:?}", key.to_lowercase().replace('_', "-"), value)
                })
                .collect::<Vec<_>>()
                .join(" ");
            println!("{{ project_name }} start {flags}");
        }
    }
    Ok(())
}

fn build_runtime_settings(
    url: String,
    auth_method: AuthMethod,
    api_version: String,
    transport: Transport,
    credentials: &HashMap<String, String>,
) -> anyhow::Result<(HashMap<String, String>, serde_json::Value)> {
    let mut env = HashMap::new();
    env.insert("{{ tool_prefix_env }}_URL".to_string(), url);
    env.insert(
        "{{ tool_prefix_env }}_AUTH_METHOD".to_string(),
        serde_json::to_value(auth_method)?
            .as_str()
            .unwrap_or_default()
            .to_string(),
    );
    env.insert("{{ tool_prefix_env }}_API_VERSION".to_string(), api_version);
    env.insert(
        "{{ tool_prefix_env }}_TRANSPORT".to_string(),
        serde_json::to_value(transport)?
            .as_str()
            .unwrap_or_default()
            .to_string(),
    );
    for (key, value) in credentials {
        {%- if "oauth2" in auth_method_keys %}
        if auth_method == AuthMethod::OAuth2
            && matches!(
                key.as_str(),
                "authorization_code" | "code_verifier" | "redirect_uri" | "token_url" | "auth_url"
            )
        {
            continue;
        }
        {%- endif %}
        env.insert(format!("{{ tool_prefix_env }}_{}", to_env_key(key)), value.clone());
    }

    let config_fields = serde_json::json!({
        "url": env.get("{{ tool_prefix_env }}_URL"),
        "auth_method": env.get("{{ tool_prefix_env }}_AUTH_METHOD"),
        "api_version": env.get("{{ tool_prefix_env }}_API_VERSION"),
        "transport": env.get("{{ tool_prefix_env }}_TRANSPORT"),
    });
    Ok((env, config_fields))
}

/// Prints a ready-to-use MCP client config (the `mcpServers` block a host
/// like Claude Code/Desktop expects) for whichever transport was selected
/// — the stdio and http shapes are mutually exclusive, never both, since
/// they're two different ways of running this same server and a client
/// only ever picks one. HTTP transport shows credentials as headers only
/// (never env/CLI args, matching `AuthManager::apply_auth_headers`'s
/// HTTP-only-uses-per-request-credentials behavior); stdio shows both the
/// `env` block and the equivalent all-CLI-args invocation, since the
/// config cascade accepts either for a spawned subprocess.
fn print_mcp_client_config(transport: Transport, auth_method: AuthMethod, env: &HashMap<String, String>) {
    match transport {
        Transport::Stdio => {
            let config = serde_json::json!({
                "mcpServers": {
                    "{{ project_name }}": {
                        "command": "{{ project_name }}",
                        "args": ["start"],
                        "env": env,
                    }
                }
            });
            println!("\nMCP client config (stdio):");
            println!("{}", serde_json::to_string_pretty(&config).unwrap());

            let cli_args = env
                .iter()
                .map(|(key, value)| format!("--{} {value:?}", key.to_lowercase().replace('_', "-")))
                .collect::<Vec<_>>()
                .join(" ");
            println!("(equivalently: `{{ project_name }} start {cli_args}`)");
        }
        Transport::Http => {
            {%- if "oauth1" in auth_method_keys %}
            if auth_method == AuthMethod::OAuth1 {
                println!(
                    "\nOAuth1 is not supported over HTTP transport: its signature must be \
                     recomputed per request against the destination URL using the server's \
                     consumer key/secret, which a simple incoming-header relay cannot \
                     provide. Use stdio transport for this API instead."
                );
                return;
            }
            {%- endif %}
            let (_, header_name) =
                {{ crate_name }}::auth::auth_manager::header_location_for(auth_method);
            let mut headers = serde_json::Map::new();
            headers.insert(
                header_name.to_string(),
                serde_json::Value::String("<credential value here>".to_string()),
            );
            let config = serde_json::json!({
                "mcpServers": {
                    "{{ project_name }}": {
                        "url": "http://127.0.0.1:3000/mcp",
                        "headers": headers,
                    }
                }
            });
            println!(
                "\nMCP client config (http) — adjust the host/port to match how you run \
                 `{{ project_name }} http`:"
            );
            println!("{}", serde_json::to_string_pretty(&config).unwrap());
            println!(
                "Credentials are never read from local config/env over HTTP transport — \
                 every request must carry its own \"{header_name}\" header."
            );
        }
    }
}

pub async fn run_setup_wizard() -> anyhow::Result<()> {
    let url = prompt_base_url().await?;
    let auth_method = prompt_auth_method().await?;
    let credentials = prompt_credentials(auth_method).await?;
    let api_version = prompt_api_version().await?;
    let transport = prompt_transport().await?;

    save_credential("active-credentials", &serde_json::to_string(&credentials)?)?;

    let (env, config_fields) =
        build_runtime_settings(url, auth_method, api_version, transport, &credentials)?;

    prompt_persistence(&env, &config_fields).await?;
    print_mcp_client_config(transport, auth_method, &env);

    let run_command = match transport {
        Transport::Stdio => "start",
        Transport::Http => "http",
    };
    println!("Setup complete! Run: {{ project_name }} {run_command}");
    Ok(())
}

{% if auth_methods | length > 0 %}#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn runtime_settings_keep_config_fields_and_filter_ephemeral_oauth_values() {
        let credentials = HashMap::from([
            ("client_id".to_string(), "client".to_string()),
            ("authorization_code".to_string(), "spent-code".to_string()),
        ]);
        let (env, config) = build_runtime_settings(
            "https://api.example/v1".to_string(),
            AuthMethod::{{ auth_methods.0.variant_name }},
            "{{ default_version_label }}".to_string(),
            Transport::Stdio,
            &credentials,
        )
        .unwrap();

        assert_eq!(config["url"], "https://api.example/v1");
        assert_eq!(config["transport"], "stdio");
        assert_eq!(env["{{ tool_prefix_env }}_CLIENT_ID"], "client");
        {%- if auth_methods.0.key == "oauth2" %}
        assert!(!env.contains_key("{{ tool_prefix_env }}_AUTHORIZATION_CODE"));
        {%- else %}
        assert_eq!(env["{{ tool_prefix_env }}_AUTHORIZATION_CODE"], "spent-code");
        {%- endif %}
    }

    #[tokio::test]
    async fn noninteractive_output_paths_cover_both_transports() {
        let credentials = HashMap::new();
        let (env, config) = build_runtime_settings(
            "https://api.example/v1".to_string(),
            // Not `prompt_auth_method().await.unwrap()`/`prompt_api_version().await.unwrap()`:
            // this test exercises the *non*-interactive output paths
            // (`persist_selection`/`print_mcp_client_config`), but those
            // prompt functions are only non-interactive themselves when
            // there's exactly one choice to make -- with more than one
            // auth method or API version they call `inquire::Select`,
            // which needs a real TTY and panics with "The input device is
            // not a TTY" in CI. Constructing the values directly (matching
            // what `print_mcp_client_config` below already hardcodes)
            // keeps this test TTY-independent regardless of how many
            // schemes/versions the spec declares.
            AuthMethod::{{ auth_methods.0.variant_name }},
            "{{ version_entries.0.label }}".to_string(),
            Transport::Http,
            &credentials,
        )
        .unwrap();
        persist_selection("Print a ready-to-run CLI invocation", &env, &config)
            .await
            .unwrap();
        print_mcp_client_config(
            Transport::Stdio,
            AuthMethod::{{ auth_methods.0.variant_name }},
            &env,
        );
        print_mcp_client_config(
            Transport::Http,
            AuthMethod::{{ auth_methods.0.variant_name }},
            &env,
        );
    }

    #[tokio::test]
    async fn file_persistence_writes_env_local_yaml_and_global_yaml() {
        let dir = tempfile::tempdir().unwrap();
        let local_dir = dir.path().join("local");
        let global_config = dir.path().join("global/config.yml");
        std::fs::create_dir_all(&local_dir).unwrap();

        let credentials = HashMap::new();
        let (env, config) = build_runtime_settings(
            "https://api.example/v1".to_string(),
            AuthMethod::{{ auth_methods.0.variant_name }},
            "{{ default_version_label }}".to_string(),
            Transport::Stdio,
            &credentials,
        )
        .unwrap();
        persist_selection_at(
            "Write a .env file",
            &env,
            &config,
            &local_dir,
            &global_config,
        )
            .await
            .unwrap();
        persist_selection_at(
            "Write a config.yml file (local — ./{{ project_name }}.config.yml, read only from this directory)",
            &env,
            &config,
            &local_dir,
            &global_config,
        )
        .await
        .unwrap();
        persist_selection_at(
            "Write a config.yml file (global — ~/.{{ project_name }}/config.yml, read on every invocation on this machine)",
            &env,
            &config,
            &local_dir,
            &global_config,
        )
        .await
        .unwrap();

        assert!(local_dir.join(".env").is_file());
        assert!(local_dir.join("{{ project_name }}.config.yml").is_file());
        assert!(global_config.is_file());
    }

    {%- if "oauth2" in auth_method_keys %}
    use tokio::io::{AsyncReadExt, AsyncWriteExt};

    fn oauth_credentials() -> HashMap<String, String> {
        HashMap::from([
            ("client_id".to_string(), "client id/with spaces".to_string()),
            (
                "auth_url".to_string(),
                "https://accounts.example/authorize".to_string(),
            ),
        ])
    }

    #[test]
    fn oauth_authorization_url_encodes_values_and_validates_inputs() {
        let mut credentials = oauth_credentials();
        let url = build_oauth_authorization(&mut credentials, "scope:a scope:b", 43210, true)
            .unwrap();
        assert!(url.contains("client_id=client%20id%2Fwith%20spaces"));
        assert!(url.contains("scope=scope%3Aa%20scope%3Ab"));
        assert!(url.contains("code_challenge_method=S256"));
        assert!(credentials.contains_key("code_verifier"));

        let mut confidential = oauth_credentials();
        assert!(!build_oauth_authorization(&mut confidential, "one", 8888, false)
            .unwrap()
            .contains("code_challenge"));
        assert!(build_oauth_authorization(&mut HashMap::new(), "one", 8888, false).is_err());
    }

    #[tokio::test]
    async fn callback_server_extracts_the_authorization_code() {
        let listener = tokio::net::TcpListener::bind("127.0.0.1:0")
            .await
            .unwrap();
        let address = listener.local_addr().unwrap();
        let callback = tokio::spawn(receive_oauth_callback(listener));
        let mut stream = tokio::net::TcpStream::connect(address).await.unwrap();
        stream
            .write_all(b"GET /callback?code=code-123 HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n")
            .await
            .unwrap();
        let mut response = String::new();
        stream.read_to_string(&mut response).await.unwrap();
        assert!(response.contains("Authorized!"));
        assert_eq!(callback.await.unwrap().unwrap(), "code-123");
    }
    {%- endif %}
}
{% endif %}
