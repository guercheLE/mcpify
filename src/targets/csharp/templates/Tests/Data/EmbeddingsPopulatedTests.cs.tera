// {{ display_name }} MCP server — generated by mcpify. Do not hand-edit.

using System.Text;
using {{ namespace }}.Data;
using Microsoft.Data.Sqlite;
using Xunit;

namespace {{ namespace }}.Tests.Data;

/// <summary>
/// Regression test for Fix 8b (embedding population completeness):
/// asserts that every version's `semantic_endpoints` row count EQUALS
/// its `endpoints` row count — not just "greater than zero". A store
/// can end up with `endpoints` rows but only some (or none) of the
/// matching `semantic_endpoints` rows if `Services/PopulateEmbeddingsService.cs`
/// was interrupted mid-run, run against a stale build, or (before
/// Fix 8a) defaulted to only the default version's store. The `search`
/// tool silently returns incomplete/empty results for an
/// under-populated version with no error ever surfaced, so this must
/// be caught here rather than discovered live.
///
/// Skipped unless <c>RUN_PACKAGING_TESTS=true</c> is set: right after
/// `mcpify generate`/`add-version`, before anyone has run
/// <c>dotnet run -- populate-embeddings --all</c>, every
/// `semantic_endpoints` table is legitimately still empty, and this
/// project's CI workflow (`.github/workflows/ci.yml`) never runs that
/// populate step before <c>dotnet test</c>. Run this explicitly as a
/// packaging/release smoke test, after populating:
///
/// <code>
/// dotnet run -- populate-embeddings --all
/// RUN_PACKAGING_TESTS=true dotnet test --filter EmbeddingsPopulatedTests
/// </code>
/// </summary>
public class EmbeddingsPopulatedTests
{
    [Fact]
    public void SemanticEndpointsRowCountMatchesEndpointsRowCountForEveryVersion()
    {
        if (Environment.GetEnvironmentVariable("RUN_PACKAGING_TESTS") != "true")
        {
            // Not run by default — see the class-level doc comment for why.
            return;
        }

        var mismatches = new StringBuilder();

        foreach (var fileName in SqliteVecStore.AllStoreFiles)
        {
            var store = new SqliteVecStore(fileName);
            using var connection = store.OpenReadOnly();

            var endpointsCount = CountRows(connection, "endpoints");
            var semanticCount = CountRows(connection, "semantic_endpoints");

            if (endpointsCount != semanticCount)
            {
                mismatches.Append($"'{fileName}': endpoints={endpointsCount} semantic_endpoints={semanticCount}; ");
            }
        }

        Assert.True(
            mismatches.Length == 0,
            "embedding population incomplete — semantic_endpoints row count must equal endpoints " +
                $"row count for every version, but found mismatch(es): {mismatches}");
    }

    private static long CountRows(SqliteConnection connection, string tableName)
    {
        using var command = connection.CreateCommand();
        command.CommandText = $"SELECT count(*) FROM {tableName}";
        return (long)command.ExecuteScalar()!;
    }
}
