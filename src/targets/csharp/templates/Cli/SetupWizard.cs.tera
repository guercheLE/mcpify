using System.Text.Json;
using Spectre.Console;
using {{ namespace }}.Auth;
using {{ namespace }}.Core;

namespace {{ namespace }}.Cli;

/// <summary>
/// Interactive setup wizard (REQ-1.6): collects the API URL and the
/// credentials the discovered auth scheme(s) need, then persists them per
/// the operator's choice: a `.env` file, a `config.json` file, or a
/// ready-to-run CLI invocation printed to stdout (nothing written to
/// disk). Mirrors `targets::python::templates::cli::setup_wizard.py`.
/// </summary>
public static class SetupWizard
{
    public static async Task RunAsync(ICredentialStore credentialStore)
    {
        var url = await PromptBaseUrlAsync();
        var authMethod = PromptAuthMethod();
        var credentials = PromptCredentials(authMethod);
        var apiVersion = PromptApiVersion();
        var transport = PromptTransport();

        await credentialStore.SaveAsync("active-credentials", JsonSerializer.Serialize(credentials));

        var env = new Dictionary<string, string>
        {
            ["{{ tool_prefix_env }}_URL"] = url,
            ["{{ tool_prefix_env }}_AUTH_METHOD"] = authMethod.ToString(),
            ["{{ tool_prefix_env }}_API_VERSION"] = apiVersion,
            ["{{ tool_prefix_env }}_TRANSPORT"] = transport.ToString(),
        };
        foreach (var (key, value) in credentials)
        {
            env[$"{{ tool_prefix_env }}_{key.ToUpperInvariant()}"] = value;
        }

        // Flat, unprefixed property names matching `Core/Config.cs`'s
        // `EnvKeyMappings` `ConfigKey` column — the shape the JSON config
        // loader actually binds (`Url`, `AuthMethod`, ...), not the
        // `{{ tool_prefix_env }}_*`-style keys used for `.env`/CLI-flag
        // output above. Deliberately excludes credential fields: those
        // stay in the credential store, never in a config file on disk.
        var configValues = new Dictionary<string, string>
        {
            ["Url"] = url,
            ["AuthMethod"] = authMethod.ToString(),
            ["ApiVersion"] = apiVersion,
            ["Transport"] = transport.ToString(),
        };

        await PromptPersistenceAsync(env, configValues);
        PrintMcpClientConfig(transport, authMethod, env);

        var runCommand = transport == Transport.Stdio ? "start" : "http";
        AnsiConsole.MarkupLine($"[green]Setup complete![/] Run: [bold]{{ project_name }} {runCommand}[/]");
    }

    private static Transport PromptTransport()
    {
        var choices = new Dictionary<string, Transport>
        {
            ["stdio (spawned as a subprocess by the MCP client)"] = Transport.Stdio,
            ["http (a standalone server the MCP client connects to over the network)"] = Transport.Http,
        };
        var selection = AnsiConsole.Prompt(
            new SelectionPrompt<string>().Title("Which transport will this deployment use?").AddChoices(choices.Keys));
        return choices[selection];
    }

    /// <summary>
    /// Prints a ready-to-use MCP client config (the <c>mcpServers</c>
    /// block a host like Claude Code/Desktop expects) for whichever
    /// transport was selected — the stdio and http shapes are mutually
    /// exclusive, never both, since they're two different ways of
    /// running this same server and a client only ever picks one. HTTP
    /// transport shows credentials as headers only (never env/CLI args,
    /// matching <see cref="AuthManager.ApplyAuthHeadersAsync"/>'s
    /// HTTP-only-uses-per-request-credentials behavior); stdio shows
    /// both the <c>env</c> block and the equivalent all-CLI-args
    /// invocation, since the config cascade accepts either for a spawned
    /// subprocess.
    /// </summary>
    private static void PrintMcpClientConfig(Transport transport, AuthMethod authMethod, Dictionary<string, string> env)
    {
        if (transport == Transport.Stdio)
        {
            var config = new Dictionary<string, object>
            {
                ["mcpServers"] = new Dictionary<string, object>
                {
                    ["{{ project_name }}"] = new Dictionary<string, object>
                    {
                        ["command"] = "{{ project_name }}",
                        ["args"] = new[] { "start" },
                        ["env"] = env,
                    },
                },
            };
            AnsiConsole.MarkupLine("\n[bold]MCP client config (stdio):[/]");
            Console.WriteLine(JsonSerializer.Serialize(config, new JsonSerializerOptions { WriteIndented = true }));
            var cliArgs = string.Join(' ', env.Select(kv => $"--{kv.Key.ToLowerInvariant().Replace('_', '-')} \"{kv.Value}\""));
            Console.WriteLine($"(equivalently: `{{ project_name }} start {cliArgs}`)");
            return;
        }

{%- if "oauth1" in auth_method_keys %}
        if (authMethod == AuthMethod.OAuth1)
        {
            AnsiConsole.MarkupLine(
                "\n[yellow]OAuth1 is not supported over HTTP transport: its signature must be recomputed per " +
                "request against the destination URL using the server's consumer key/secret, which a simple " +
                "incoming-header relay cannot provide. Use stdio transport for this API instead.[/]");
            return;
        }
{%- endif %}
        var (_, headerName) = AuthManager.HeaderLocationFor(authMethod);
        var httpConfig = new Dictionary<string, object>
        {
            ["mcpServers"] = new Dictionary<string, object>
            {
                ["{{ project_name }}"] = new Dictionary<string, object>
                {
                    ["url"] = "http://127.0.0.1:3000/mcp",
                    ["headers"] = new Dictionary<string, string> { [headerName] = "<credential value here>" },
                },
            },
        };
        AnsiConsole.MarkupLine("\n[bold]MCP client config (http)[/] — adjust the host/port to match how you run `{{ project_name }} http`:");
        Console.WriteLine(JsonSerializer.Serialize(httpConfig, new JsonSerializerOptions { WriteIndented = true }));
        Console.WriteLine(
            $"Credentials are never read from local config/env over HTTP transport — every request must carry its own \"{headerName}\" header.");
    }

    private static async Task<string> PromptBaseUrlAsync()
    {
        var url = AnsiConsole.Ask<string>("{{ display_name }} base URL:");

        try
        {
            using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(5) };
            await client.SendAsync(new HttpRequestMessage(HttpMethod.Head, url));
            AnsiConsole.MarkupLine("[green]reachable[/]");
        }
        catch (Exception)
        {
            AnsiConsole.MarkupLine(
                "[yellow]could not reach that URL yet — continuing anyway (fix it later with `test-connection`)[/]");
        }

        return url;
    }

    private static AuthMethod PromptAuthMethod()
    {
{%- if auth_methods | length <= 1 %}
        // {% if auth_methods | length == 1 %}Exactly one scheme was discovered{% else %}No scheme was discovered{% endif %} — nothing to choose between.
        return AuthMethod.{% if auth_methods | length == 1 %}{{ auth_methods.0.class_name }}{% else %}None{% endif %};
{%- else %}
        var choices = new Dictionary<string, AuthMethod>
        {
{%- for method in auth_methods %}
            ["{{ method.key }}"] = AuthMethod.{{ method.class_name }},
{%- endfor %}
        };
        var selection = AnsiConsole.Prompt(
            new SelectionPrompt<string>().Title("Authentication method:").AddChoices(choices.Keys));
        return choices[selection];
{%- endif %}
    }

    // mcpify:versions:begin
    private static string PromptApiVersion()
    {
{%- if version_entries | length <= 1 %}
        // Only one version is available — nothing to choose between.
        return "{{ version_entries.0.label }}";
{%- else %}
        var choices = new Dictionary<string, string>
        {
{%- for v in version_entries %}
            ["{{ v.label }}{% if v.label == default_version_label %} (default/latest){% endif %}"] = "{{ v.label }}",
{%- endfor %}
        };
        var selection = AnsiConsole.Prompt(
            new SelectionPrompt<string>().Title("API version to use:").AddChoices(choices.Keys));
        return choices[selection];
{%- endif %}
    }
    // mcpify:versions:end

    private static Dictionary<string, string> PromptCredentials(AuthMethod authMethod)
    {
        var credentials = new Dictionary<string, string>();
{%- if "basic" in auth_method_keys %}
        if (authMethod == AuthMethod.Basic)
        {
            credentials["username"] = AnsiConsole.Ask<string>("Username:");
            credentials["password"] = AnsiConsole.Prompt(new TextPrompt<string>("Password:").Secret());
        }
{%- endif %}
{%- if "pat" in auth_method_keys %}
        if (authMethod == AuthMethod.Pat)
        {
            credentials["token"] = AnsiConsole.Prompt(new TextPrompt<string>("Personal access token:").Secret());
        }
{%- endif %}
{%- if "apiKey" in auth_method_keys %}
        if (authMethod == AuthMethod.ApiKey)
        {
            credentials["api_key"] = AnsiConsole.Prompt(new TextPrompt<string>("API key:").Secret());
        }
{%- endif %}
{%- if "oauth2" in auth_method_keys %}
        if (authMethod == AuthMethod.OAuth2)
        {
            credentials["client_id"] = AnsiConsole.Ask<string>("OAuth2 client ID:");
            var clientSecret = AnsiConsole.Prompt(
                new TextPrompt<string>("OAuth2 client secret (leave blank if none):").Secret().AllowEmpty());
            if (!string.IsNullOrEmpty(clientSecret))
            {
                credentials["client_secret"] = clientSecret;
            }
            credentials["token_url"] = AnsiConsole.Ask<string>("OAuth2 token URL:");
            var authorizationCode = AnsiConsole.Prompt(
                new TextPrompt<string>("Authorization code, if you already have one (leave blank to skip):")
                    .AllowEmpty());
            if (!string.IsNullOrEmpty(authorizationCode))
            {
                credentials["authorization_code"] = authorizationCode;
            }
        }
{%- endif %}
{%- if "oauth1" in auth_method_keys %}
        if (authMethod == AuthMethod.OAuth1)
        {
            credentials["consumer_key"] = AnsiConsole.Ask<string>("OAuth1 consumer key:");
            var privateKeyPath = AnsiConsole.Ask<string>("Path to RSA private key file:");
            credentials["private_key"] = File.ReadAllText(privateKeyPath);
        }
{%- endif %}
        return credentials;
    }

    /// <summary>
    /// Persists settings per the operator's choice. The config.json branch
    /// writes to exactly one of the two paths <c>Core/Config.cs</c>'s
    /// loader actually reads — the user home-directory tier
    /// (<c>~/.{{ project_name }}/config.json</c>) or the local
    /// working-directory tier (<c>./{{ project_name }}.config.json</c>) —
    /// using the flat unprefixed property-name shape that tier's
    /// <c>AddJsonFile</c> binder expects, so the written file is actually
    /// read back on the next run instead of silently ignored.
    /// </summary>
    private static async Task PromptPersistenceAsync(Dictionary<string, string> env, Dictionary<string, string> configValues)
    {
        var choices = new[]
        {
            "Write a .env file",
            "Write a config.json file",
            "Print a ready-to-run CLI invocation (nothing written to disk)",
        };
        var selection = AnsiConsole.Prompt(
            new SelectionPrompt<string>().Title("How should these settings be saved?").AddChoices(choices));

        if (selection == choices[0])
        {
            var contents = string.Join('\n', env.Select(kv => $"{kv.Key}={kv.Value}"));
            await File.WriteAllTextAsync(".env", contents + "\n");
            AnsiConsole.MarkupLine("Wrote .env");
        }
        else if (selection == choices[1])
        {
            var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
            var globalPath = Path.Combine(home, ".{{ project_name }}", "config.json");
            var localPath = Path.Combine(Directory.GetCurrentDirectory(), "{{ project_name }}.config.json");
            var locationChoices = new Dictionary<string, string>
            {
                [$"Globally ({globalPath} — used on every run regardless of working directory)"] = globalPath,
                [$"Locally ({localPath} — used only when run from this directory)"] = localPath,
            };
            var locationSelection = AnsiConsole.Prompt(
                new SelectionPrompt<string>().Title("Write it globally or locally?").AddChoices(locationChoices.Keys));
            var path = locationChoices[locationSelection];

            var directory = Path.GetDirectoryName(path);
            if (!string.IsNullOrEmpty(directory))
            {
                Directory.CreateDirectory(directory);
            }

            await File.WriteAllTextAsync(
                path, JsonSerializer.Serialize(configValues, new JsonSerializerOptions { WriteIndented = true }));
            AnsiConsole.MarkupLine($"Wrote {path}");
        }
        else
        {
            var flags = string.Join(' ', env.Select(kv => $"--{kv.Key.ToLowerInvariant().Replace('_', '-')} \"{kv.Value}\""));
            AnsiConsole.MarkupLine($"{{ project_name }} start {flags}");
        }
    }
}
