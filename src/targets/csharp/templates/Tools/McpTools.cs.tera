using System.ComponentModel;
using System.Text.Json;
using System.Text.Json.Nodes;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Options;
using ModelContextProtocol.Server;
using {{ namespace }}.Core;
using {{ namespace }}.Data;
using {{ namespace }}.Http;
using {{ namespace }}.Services;
using {{ namespace }}.Validation;

namespace {{ namespace }}.Tools;

/// <summary>
/// PRD §1.5's `search`/`get`/`call` — exactly 3 tools, regardless of how
/// many operations the source spec declares, so an LLM never needs the
/// full API surface in context. Non-<see cref="Description"/>-decorated
/// parameters (<see cref="SqliteVecStore"/>, <see cref="EmbeddingService"/>,
/// <see cref="ApiClient"/>) are DI-injected by the MCP SDK's own
/// `WithToolsFromAssembly()` scan, per the SDK's documented pattern.
/// </summary>
[McpServerToolType]
public static class McpTools
{
    [McpServerTool(Name = "search")]
    [Description("Semantic search for operations matching a natural-language query.")]
    public static async Task<string> Search(
        SqliteVecStore store,
        EmbeddingService embeddingService,
        [Description("Natural-language description of the operation to find")] string query,
        [Description("Maximum number of results to return")] int limit = 5)
    {
        var queryEmbedding = await embeddingService.EmbedAsync(query);
        var results = store.SearchEndpoints(queryEmbedding, limit);
        return JsonSerializer.Serialize(results);
    }

    [McpServerTool(Name = "get")]
    [Description("Show the schema, path, method, and documentation for one operation.")]
    public static string Get(
        SqliteVecStore store,
        [Description("The operationId to look up")] string operationId)
    {
        var endpoint = store.GetEndpoint(operationId)
            ?? throw new McpifyNotFoundException($"unknown operationId '{operationId}'");
        return JsonSerializer.Serialize(endpoint);
    }

    [McpServerTool(Name = "call")]
    [Description("Validate arguments, invoke the live API, and validate the response.")]
    public static async Task<string> Call(
        SqliteVecStore store,
        ApiClient apiClient,
        IOptions<McpifyOptions> options,
        IRequestCredentialProvider credentialProvider,
        ILoggerFactory loggerFactory,
        [Description("The operationId to invoke")] string operationId,
        [Description("JSON object of arguments for the operation")] string args)
    {
        // ILoggerFactory.CreateLogger(string), not ILogger<McpTools>: McpTools
        // is a static class, and C# doesn't allow a static type as a generic
        // type argument (CS0718).
        var logger = loggerFactory.CreateLogger("McpTools");

        var endpoint = store.GetEndpoint(operationId)
            ?? throw new McpifyNotFoundException($"unknown operationId '{operationId}'");

        var argsNode = JsonNode.Parse(args) as JsonObject ?? [];
        Validator.ValidateInput(options.Value.ApiVersion, operationId, argsNode);

        var argsDict = argsNode.ToDictionary(kv => kv.Key, kv => kv.Value);
        // HTTP transport only: credentialProvider resolves this call's own
        // request credentials from ASP.NET Core's per-request DI scope —
        // null on stdio (or the bundled CLI's direct in-process calls),
        // where there's no HttpContext at all.
        var response = await apiClient.ExecuteAsync(endpoint, argsDict, credentialProvider.GetOverride());

        // An output-schema mismatch is only logged, not thrown: real-world
        // OpenAPI specs (e.g. Atlassian's published Jira Data Center spec)
        // are frequently wrong about response shape — declaring a single
        // object where the API actually returns an array, or an overly
        // narrow additionalProperties for a free-form bag of fields — and
        // rejecting an otherwise-successful call over a documentation bug
        // would deny the caller real data it already has in hand. Input
        // validation still throws: those arguments are under the caller's
        // control, not the upstream API's.
        try
        {
            Validator.ValidateOutput(options.Value.ApiVersion, operationId, response);
        }
        catch (ValidationException ex)
        {
            logger.LogWarning(
                "operationId={OperationId}: response did not match the documented schema; returning it as-is: {Error}",
                operationId,
                ex.Message);
        }
        return response?.ToJsonString() ?? "null";
    }
}
