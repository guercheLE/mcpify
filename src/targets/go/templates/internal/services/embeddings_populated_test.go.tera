//go:build integration

// {{ display_name }} MCP server — generated by mcpify. Do not hand-edit.

package services

import (
	"context"
	"errors"
	"fmt"
	"path/filepath"
	"testing"

	"{{ module_path }}/internal/data"
)

// TestSemanticEndpointsCountMatchesEndpointsCountForEveryVersion is a
// regression test for Fix 8b (embedding population completeness):
// asserts that every version's chromem-go vector collection holds
// exactly as many documents as mcp_store*.db's `endpoints` table has
// rows — not just "more than zero". A version can end up with
// `endpoints` rows but only some (or none) of them indexed into
// chromem-go if `cmd/populate-embeddings` was interrupted mid-run, run
// against a stale binary, or (before Fix 8a) defaulted to only the
// default version's store. The `search` tool silently returns
// incomplete/empty results for an under-populated version with no error
// ever surfaced, so this must be caught here rather than discovered
// live.
//
// Gated by the "integration" build tag exactly like this package's
// TestEmbeddingServiceProducesCorrectlyOrderedSimilarities sibling test
// (`go test -tags=integration`), not run by default `go test ./...`
// (and so not run by this project's CI workflow): right after `mcpify
// generate`/`add-version`, before anyone has run
// `populate-embeddings --all`, every chromem-go collection is
// legitimately still empty relative to `endpoints`. Run this explicitly
// as a packaging/release smoke test, after populating:
//
//	go run ./cmd/populate-embeddings --all
//	go test -tags=integration ./internal/services/... -run SemanticEndpointsCountMatchesEndpointsCountForEveryVersion
func TestSemanticEndpointsCountMatchesEndpointsCountForEveryVersion(t *testing.T) {
	var mismatches []string
	for label, dbPath := range data.VersionStoreFiles {
		// data.VersionStoreFiles/ChromemPathFor return paths relative to
		// the module root — correct for the compiled binary (always run
		// from the project root, per this target's README/Dockerfile) and
		// for `cmd/populate-embeddings`, but `go test` runs every
		// package's tests with that package's own directory as the
		// working directory, not the module root. This test lives 2
		// directories below the module root (internal/services), so its
		// relative paths need that same prefix restored.
		store, err := data.Open(moduleRootRelative(dbPath))
		if err != nil {
			t.Fatalf("failed to open store for '%s' (%s): %v", label, dbPath, err)
		}

		endpoints, err := store.ListEndpoints()
		if err != nil {
			_ = store.Close()
			t.Fatalf("failed to list endpoints for '%s': %v", label, err)
		}
		_ = store.Close()

		relativeChromemPath, err := data.ChromemPathFor(label)
		if err != nil {
			t.Fatalf("failed to resolve chromem path for '%s': %v", label, err)
		}
		chromemPath := moduleRootRelative(relativeChromemPath)

		// No documents are added here, only counted — GetOrCreateCollection
		// loads whatever chromem-go already persisted to chromemPath on an
		// earlier populate-embeddings run, so this embedding function is
		// never actually invoked.
		unusedEmbed := func(context.Context, string) ([]float32, error) {
			return nil, errors.New("embeddings_populated_test: embedding function must not be called")
		}
		vectorStore, err := NewVectorStore(chromemPath, unusedEmbed)
		if err != nil {
			t.Fatalf("failed to open vector store for '%s' (%s): %v", label, chromemPath, err)
		}

		endpointsCount := len(endpoints)
		semanticCount := vectorStore.Count()
		if endpointsCount != semanticCount {
			mismatches = append(mismatches, fmt.Sprintf(
				"'%s': endpoints=%d semantic=%d", label, endpointsCount, semanticCount,
			))
		}
	}

	if len(mismatches) > 0 {
		t.Fatalf(
			"embedding population incomplete — vector collection document count must equal "+
				"endpoints row count for every version, but found mismatch(es): %v",
			mismatches,
		)
	}
}

// moduleRootRelative rebases a data.VersionStoreFiles/ChromemPathFor path
// (relative to the module root) onto this package's own directory
// (internal/services, 2 levels below root) — see the doc comment above.
func moduleRootRelative(path string) string {
	return filepath.Join("..", "..", path)
}
