// RunSetup interactively collects the API URL and the credentials the
// discovered auth scheme(s) need, then persists them per the operator's
// choice: a .env file, a config.json file, or a ready-to-run CLI
// invocation printed to stdout (nothing written to disk). Mirrors
// `targets::csharp::templates::Cli::SetupWizard.cs.tera`.
func RunSetup(ctx context.Context, overrides core.CLIOverrides) error {
	url, err := promptBaseURL(ctx)
	if err != nil {
		return err
	}

	authMethod := promptAuthMethod()
	credentials, err := promptCredentials(ctx, authMethod)
	if err != nil {
		return err
	}
	apiVersion := promptApiVersion()
	transport := promptTransport()

	credentialStore, err := core.NewCredentialStore()
	if err != nil {
		return err
	}
	encoded, err := json.Marshal(credentials)
	if err != nil {
		return err
	}
	if err := credentialStore.Save("active-credentials", string(encoded)); err != nil {
		return err
	}

	env := map[string]string{
		"{{ tool_prefix_env }}_URL":         url,
		"{{ tool_prefix_env }}_AUTH_METHOD": string(authMethod),
		"{{ tool_prefix_env }}_API_VERSION": apiVersion,
		"{{ tool_prefix_env }}_TRANSPORT":   string(transport),
	}
	for key, value := range credentials {
		{%- if "oauth2" in auth_method_keys %}
		if authMethod == core.AuthMethodOAuth2 {
			switch key {
			case "authorization_code", "code_verifier", "redirect_uri", "token_url":
				// Single-use (authorization_code, code_verifier — an
				// authorization code is spent in minutes and a PKCE
				// verifier is useless without it) or provider-fixed
				// (redirect_uri, token_url — already baked into the
				// keychain blob credentialStore.Save wrote above)
				// fields. Persisting these to .env/config.json/CLI args
				// would either leak a spent code or go stale the moment
				// the provider rotates an endpoint.
				continue
			}
		}
		{%- endif %}
		env["{{ tool_prefix_env }}_"+strings.ToUpper(key)] = value
	}

	if err := promptPersistence(env, url, authMethod, apiVersion, transport); err != nil {
		return err
	}
	printMcpClientConfig(transport, authMethod, env)

	runCommand := "start"
	if transport == core.TransportHTTP {
		runCommand = "http"
	}
	fmt.Printf("Setup complete! Run: {{ project_name }} %s\n", runCommand)
	return nil
}

func promptTransport() core.Transport {
	options := []string{
		"stdio (spawned as a subprocess by the MCP client)",
		"http (a standalone server the MCP client connects to over the network)",
	}
	var selection string
	_ = survey.AskOne(&survey.Select{Message: "Which transport will this deployment use?", Options: options}, &selection)
	if strings.HasPrefix(selection, "stdio") {
		return core.TransportStdio
	}
	return core.TransportHTTP
}

// printMcpClientConfig prints a ready-to-use MCP client config (the
// mcpServers block a host like Claude Code/Desktop expects) for whichever
// transport was selected — the stdio and http shapes are mutually
// exclusive, never both, since they're two different ways of running
// this same server and a client only ever picks one. HTTP transport shows
// credentials as headers only (never env/CLI args, matching
// auth.Manager.ApplyAuthHeaders's HTTP-only-uses-per-request-credentials
// behavior); stdio shows both the env block and the equivalent
// all-CLI-args invocation, since the config cascade accepts either for a
// spawned subprocess.
func printMcpClientConfig(transport core.Transport, authMethod core.AuthMethod, env map[string]string) {
	keys := make([]string, 0, len(env))
	for key := range env {
		keys = append(keys, key)
	}
	sort.Strings(keys)

	if transport == core.TransportStdio {
		config := map[string]any{
			"mcpServers": map[string]any{
				"{{ project_name }}": map[string]any{
					"command": "{{ project_name }}",
					"args":    []string{"start"},
					"env":     env,
				},
			},
		}
		fmt.Println("\nMCP client config (stdio):")
		encoded, _ := json.MarshalIndent(config, "", "  ")
		fmt.Println(string(encoded))

		flags := make([]string, 0, len(keys))
		for _, key := range keys {
			flag := strings.ToLower(strings.ReplaceAll(key, "_", "-"))
			flags = append(flags, fmt.Sprintf("--%s %q", flag, env[key]))
		}
		fmt.Printf("(equivalently: `{{ project_name }} start %s`)\n", strings.Join(flags, " "))
		return
	}

{%- if "oauth1" in auth_method_keys %}
	if authMethod == core.AuthMethodOAuth1 {
		fmt.Println("\nOAuth1 is not supported over HTTP transport: its signature must be recomputed per request against the destination URL using the server's consumer key/secret, which a simple incoming-header relay cannot provide. Use stdio transport for this API instead.")
		return
	}
{%- endif %}
	_, headerName := auth.HeaderLocationFor(authMethod)
	config := map[string]any{
		"mcpServers": map[string]any{
			"{{ project_name }}": map[string]any{
				"url":     "http://127.0.0.1:3000/mcp",
				"headers": map[string]string{headerName: "<credential value here>"},
			},
		},
	}
	fmt.Println("\nMCP client config (http) — adjust the host/port to match how you run `{{ project_name }} http`:")
	encoded, _ := json.MarshalIndent(config, "", "  ")
	fmt.Println(string(encoded))
	fmt.Printf("Credentials are never read from local config/env over HTTP transport — every request must carry its own %q header.\n", headerName)
}

func promptBaseURL(ctx context.Context) (string, error) {
	var url string
	if err := survey.AskOne(&survey.Input{Message: "{{ display_name }} base URL:"}, &url, survey.WithValidator(survey.Required)); err != nil {
		return "", err
	}

	client := &http.Client{Timeout: 5 * time.Second}
	req, err := http.NewRequestWithContext(ctx, http.MethodHead, url, http.NoBody)
	if err == nil {
		if resp, err := client.Do(req); err == nil {
			_ = resp.Body.Close()
			fmt.Println("reachable")
		} else {
			fmt.Println("could not reach that URL yet — continuing anyway (fix it later with `test-connection`)")
		}
	}

	return url, nil
}

func promptAuthMethod() core.AuthMethod {
{%- if auth_methods | length == 0 %}
	// No scheme was discovered — nothing to choose between.
	return core.AuthMethodNone
{%- elif auth_methods | length == 1 %}
	// Exactly one scheme was discovered — nothing to choose between.
	return core.AuthMethod{{ auth_methods.0.type_name }}
{%- else %}
	// Built as individual assignments rather than one map literal — gofmt
	// column-aligns every entry in a multi-line map literal by the longest
	// key, which a Tera template can't predict ahead of rendering since
	// the set of discovered schemes varies per generation (the same
	// reason `internal/core/config.go.tera`'s per-method consts are
	// ungrouped statements instead of one `const (...)` block).
	choices := map[string]core.AuthMethod{}
{%- for method in auth_methods %}
	choices["{{ method.key }}"] = core.AuthMethod{{ method.type_name }}
{%- endfor %}
	options := make([]string, 0, len(choices))
	for key := range choices {
		options = append(options, key)
	}
	sort.Strings(options)

	var selection string
	_ = survey.AskOne(&survey.Select{Message: "Authentication method:", Options: options}, &selection)
	return choices[selection]
{%- endif %}
}

// mcpify:versions:begin
func promptApiVersion() string {
{%- if version_entries | length <= 1 %}
	// Only one version is available — nothing to choose between.
	return "{{ version_entries.0.label }}"
{%- else %}
	choices := map[string]string{}
{%- for v in version_entries %}
	choices["{{ v.label }}{% if v.label == default_version_label %} (default/latest){% endif %}"] = "{{ v.label }}"
{%- endfor %}
	options := make([]string, 0, len(choices))
	for key := range choices {
		options = append(options, key)
	}
	sort.Strings(options)

	var selection string
	_ = survey.AskOne(&survey.Select{Message: "API version to use:", Options: options}, &selection)
	return choices[selection]
{%- endif %}
}

// mcpify:versions:end

{%- if "oauth2" in auth_method_keys %}
{%- for method in auth_methods %}
{%- if method.key == "oauth2" %}

type oauth2Setup struct {
	Credentials  map[string]string
	AuthURL      string
	UseCallback  bool
	CallbackPort int
}

// buildOAuth2Setup collects client ID/secret, scopes, generates PKCE, and
// builds the authorization URL — everything the browser step needs, before
// this wizard starts (or skips) the local callback server.
func buildOAuth2Setup() (oauth2Setup, error) {
	fmt.Println()
	fmt.Println("══════════════════════════════════════════════════════════════════════")
	fmt.Println("{{ display_name }} OAuth2 Setup")
	fmt.Println("You need an OAuth2 app registered with this API provider.")
	fmt.Println("══════════════════════════════════════════════════════════════════════")

	credentials := map[string]string{}

	// Client ID and secret aren't per-user secrets — RFC 8252 classifies
	// CLI/native apps as OAuth "public clients": client_id is a bare
	// identifier, and even a client_secret (when one exists — PKCE is the
	// actual protection for this class of client) "should not be treated
	// as confidential". So, unlike the actual tokens this wizard goes on
	// to collect, it's fine to default these from env vars — the same
	// convenience pattern gcloud/aws-style CLIs use for app-level config,
	// letting an operator re-run setup without retyping their app's
	// identity every time.
	envClientID := os.Getenv("{{ tool_prefix_env }}_CLIENT_ID")
	envClientSecret := os.Getenv("{{ tool_prefix_env }}_CLIENT_SECRET")

	clientIDPrompt := &survey.Input{Message: "OAuth2 client ID:"}
	if envClientID != "" {
		clientIDPrompt.Default = envClientID
	}
	var clientID string
	if err := survey.AskOne(clientIDPrompt, &clientID); err != nil {
		return oauth2Setup{}, err
	}
	credentials["client_id"] = clientID

	var clientSecret string
	if envClientSecret != "" {
		fmt.Println("Client Secret: using {{ tool_prefix_env }}_CLIENT_SECRET from the environment.")
		clientSecret = envClientSecret
	} else {
		_ = survey.AskOne(&survey.Password{
			Message: "OAuth2 client secret (leave blank to use PKCE-only — recommended, no secret required):",
		}, &clientSecret)
	}
	usePKCE := clientSecret == ""
	if !usePKCE {
		credentials["client_secret"] = clientSecret
	}

	tokenURLPrompt := &survey.Input{Message: "OAuth2 token URL:"}
	{%- if method.token_url %}
	tokenURLPrompt.Default = "{{ method.token_url }}"
	{%- endif %}
	var tokenURL string
	if err := survey.AskOne(tokenURLPrompt, &tokenURL); err != nil {
		return oauth2Setup{}, err
	}
	credentials["token_url"] = tokenURL

	authBasePrompt := &survey.Input{Message: "OAuth2 authorization URL (where the browser goes to authorize):"}
	{%- if method.authorization_url %}
	authBasePrompt.Default = "{{ method.authorization_url }}"
	{%- endif %}
	var authBase string
	if err := survey.AskOne(authBasePrompt, &authBase); err != nil {
		return oauth2Setup{}, err
	}

	scopePrompt := &survey.Input{Message: "OAuth2 scopes (space-separated — accept the default for full access):"}
	{%- if method.scopes %}
	scopePrompt.Default = "{{ method.scopes }}"
	{%- endif %}
	var scope string
	if err := survey.AskOne(scopePrompt, &scope); err != nil {
		return oauth2Setup{}, err
	}

	// Redirect URI — MUST be registered with the OAuth2 app.
	callbackPort := 8888
	redirectURI := fmt.Sprintf("http://127.0.0.1:%d/callback", callbackPort)
	credentials["redirect_uri"] = redirectURI

	// PKCE: generate code_verifier/code_challenge when not using a secret.
	var codeChallenge string
	if usePKCE {
		verifier, challenge, err := auth.NewPKCEPair()
		if err != nil {
			return oauth2Setup{}, err
		}
		credentials["code_verifier"] = verifier
		codeChallenge = challenge
	}

	// Build the authorization URL. The user opens this in their browser to
	// grant permission; the provider then redirects to
	// redirect_uri?code=<authorization_code>.
	params := url.Values{}
	params.Set("response_type", "code")
	params.Set("client_id", clientID)
	params.Set("redirect_uri", redirectURI)
	params.Set("scope", scope)
	if codeChallenge != "" {
		params.Set("code_challenge_method", "S256")
		params.Set("code_challenge", codeChallenge)
	}
	authURL := authBase + "?" + params.Encode()

	useCallback := true
	_ = survey.AskOne(&survey.Confirm{
		Message: fmt.Sprintf(
			"Start a local callback server on %s to capture the\nauthorization code automatically after you authorize in the browser?",
			redirectURI,
		),
		Default: true,
	}, &useCallback)

	return oauth2Setup{
		Credentials:  credentials,
		AuthURL:      authURL,
		UseCallback:  useCallback,
		CallbackPort: callbackPort,
	}, nil
}

// waitForOAuthCallback starts a temporary local HTTP server that receives
// the OAuth2 redirect, extracts the `?code=` query parameter, then shuts
// itself down.
func waitForOAuthCallback(ctx context.Context, port int) (string, error) {
	codeCh := make(chan string, 1)
	mux := http.NewServeMux()
	mux.HandleFunc("/callback", func(w http.ResponseWriter, r *http.Request) {
		code := r.URL.Query().Get("code")
		w.Header().Set("Content-Type", "text/html")
		_, _ = w.Write([]byte(
			"<!DOCTYPE html><html><body><h1>&#10003; Authorized!</h1>" +
				"<p>Return to your terminal &mdash; setup continues automatically.</p></body></html>",
		))
		select {
		case codeCh <- code:
		default:
		}
	})
	server := &http.Server{Addr: fmt.Sprintf("127.0.0.1:%d", port), Handler: mux}

	listener, err := net.Listen("tcp", server.Addr)
	if err != nil {
		return "", err
	}
	go func() {
		_ = server.Serve(listener)
	}()
	defer func() {
		shutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
		defer cancel()
		_ = server.Shutdown(shutdownCtx)
	}()

	select {
	case code := <-codeCh:
		return code, nil
	case <-time.After(300 * time.Second):
		return "", fmt.Errorf("timed out waiting for the OAuth2 callback (5 minutes)")
	case <-ctx.Done():
		return "", ctx.Err()
	}
}
{%- endif %}
{%- endfor %}
{%- endif %}

func promptCredentials(ctx context.Context, authMethod core.AuthMethod) (map[string]string, error) {
	credentials := map[string]string{}
{%- if "basic" in auth_method_keys %}
	if authMethod == core.AuthMethodBasic {
		var username, password string
		if err := survey.AskOne(&survey.Input{Message: "Username:"}, &username); err != nil {
			return nil, err
		}
		if err := survey.AskOne(&survey.Password{Message: "Password:"}, &password); err != nil {
			return nil, err
		}
		credentials["username"] = username
		credentials["password"] = password
	}
{%- endif %}
{%- if "pat" in auth_method_keys %}
	if authMethod == core.AuthMethodPat {
		var token string
		if err := survey.AskOne(&survey.Password{Message: "Personal access token:"}, &token); err != nil {
			return nil, err
		}
		credentials["token"] = token
	}
{%- endif %}
{%- if "apiKey" in auth_method_keys %}
	if authMethod == core.AuthMethodApiKey {
		var apiKey string
		if err := survey.AskOne(&survey.Password{Message: "API key:"}, &apiKey); err != nil {
			return nil, err
		}
		credentials["api_key"] = apiKey
	}
{%- endif %}
{%- if "oauth2" in auth_method_keys %}
	if authMethod == core.AuthMethodOAuth2 {
		setup, err := buildOAuth2Setup()
		if err != nil {
			return nil, err
		}

		bar := strings.Repeat("═", 72)
		fmt.Printf("\n%s\n", bar)
		fmt.Println("Open this URL in your browser to authorize:")
		fmt.Println(setup.AuthURL)
		fmt.Println(bar)
		fmt.Printf(
			"\nIMPORTANT: Before opening the URL, register this Redirect URI with your OAuth2 app:\n  http://127.0.0.1:%d/callback\n\n",
			setup.CallbackPort,
		)

		var authorizationCode string
		if setup.UseCallback {
			fmt.Printf("Waiting for callback on http://127.0.0.1:%d/callback …\n", setup.CallbackPort)
			authorizationCode, err = waitForOAuthCallback(ctx, setup.CallbackPort)
			if err != nil {
				return nil, err
			}
		} else {
			if err := survey.AskOne(&survey.Input{
				Message: "Paste the authorization code from the redirect URL (?code=...):",
			}, &authorizationCode); err != nil {
				return nil, err
			}
		}

		for key, value := range setup.Credentials {
			credentials[key] = value
		}
		credentials["authorization_code"] = authorizationCode
	}
{%- endif %}
{%- if "oauth1" in auth_method_keys %}
	if authMethod == core.AuthMethodOAuth1 {
		var consumerKey, privateKeyPath string
		if err := survey.AskOne(&survey.Input{Message: "OAuth1 consumer key:"}, &consumerKey); err != nil {
			return nil, err
		}
		if err := survey.AskOne(&survey.Input{Message: "Path to RSA private key file:"}, &privateKeyPath); err != nil {
			return nil, err
		}
		keyBytes, err := os.ReadFile(privateKeyPath)
		if err != nil {
			return nil, err
		}
		credentials["consumer_key"] = consumerKey
		credentials["private_key"] = string(keyBytes)
	}
{%- endif %}
	return credentials, nil
}

// configFileOverrides mirrors internal/core/config.go.tera's fileOverrides
// JSON shape exactly (flat, unprefixed, camelCase keys) — the loader's
// `applyFile` unmarshals into that same shape at both the local-cwd and
// global-home tiers, so this is the one JSON key set that actually gets
// read back. Only the fields the wizard collected are set; the rest stay
// nil/omitted so the loader's defaults and other cascade tiers are
// untouched. Credentials are deliberately never included here — they
// already went through core.NewCredentialStore()/credentialStore.Save
// above, and must keep going through that path, not this file.
type configFileOverrides struct {
	URL        string `json:"url"`
	AuthMethod string `json:"authMethod"`
	ApiVersion string `json:"apiVersion"`
	Transport  string `json:"transport"`
}

func promptPersistence(env map[string]string, url string, authMethod core.AuthMethod, apiVersion string, transport core.Transport) error {
	options := []string{
		"Write a .env file",
		"Write a config.json file",
		"Print a ready-to-run CLI invocation (nothing written to disk)",
	}
	var selection string
	if err := survey.AskOne(&survey.Select{Message: "How should these settings be saved?", Options: options}, &selection); err != nil {
		return err
	}

	keys := make([]string, 0, len(env))
	for key := range env {
		keys = append(keys, key)
	}
	sort.Strings(keys)

	switch selection {
	case options[0]:
		lines := make([]string, 0, len(keys))
		for _, key := range keys {
			lines = append(lines, fmt.Sprintf("%s=%s", key, env[key]))
		}
		if err := os.WriteFile(".env", []byte(strings.Join(lines, "\n")+"\n"), 0o600); err != nil {
			return err
		}
		fmt.Println("Wrote .env")
	case options[1]:
		configPath, err := promptConfigFilePath()
		if err != nil {
			return err
		}
		overrides := configFileOverrides{
			URL:        url,
			AuthMethod: string(authMethod),
			ApiVersion: apiVersion,
			Transport:  string(transport),
		}
		encoded, err := json.MarshalIndent(overrides, "", "  ")
		if err != nil {
			return err
		}
		if dir := filepath.Dir(configPath); dir != "." {
			if err := os.MkdirAll(dir, 0o700); err != nil {
				return err
			}
		}
		if err := os.WriteFile(configPath, encoded, 0o600); err != nil {
			return err
		}
		fmt.Printf("Wrote %s\n", configPath)
	default:
		flags := make([]string, 0, len(keys))
		for _, key := range keys {
			flag := strings.ToLower(strings.ReplaceAll(key, "_", "-"))
			flags = append(flags, fmt.Sprintf("--%s %q", flag, env[key]))
		}
		fmt.Printf("{{ project_name }} start %s\n", strings.Join(flags, " "))
	}
	return nil
}

// promptConfigFilePath asks whether to persist config.json globally (the
// home-dir tier internal/core/config.go.tera's Load reads via
// `filepath.Join(home, ".{{ project_name }}", "config.json")`) or locally
// (the cwd tier it reads via `filepath.Join(cwd, "{{ project_name }}.config.json")`)
// — the exact two filenames/paths the loader's cascade actually checks, so
// whichever the operator picks is read back on the very next run instead of
// silently ignored.
func promptConfigFilePath() (string, error) {
	globalLabel := "Globally (~/.{{ project_name }}/config.json — applies to every project directory)"
	localLabel := "Locally (./{{ project_name }}.config.json — this directory only)"
	options := []string{globalLabel, localLabel}
	var selection string
	if err := survey.AskOne(&survey.Select{Message: "Write config.json globally or locally?", Options: options}, &selection); err != nil {
		return "", err
	}

	if selection == globalLabel {
		home, err := os.UserHomeDir()
		if err != nil {
			return "", fmt.Errorf("resolving home directory for global config: %w", err)
		}
		return filepath.Join(home, ".{{ project_name }}", "config.json"), nil
	}
	return "{{ project_name }}.config.json", nil
}
